---
import PageLayout from '../../layouts/PageLayout.astro';

export const prerender = true;

const title = 'Contact Bloomwood Solutions';
const description =
  'Need help with your computer or tech? Call, email, or book support with Bloomwood Solutions for fast, friendly help across the Cairns region.';
---

<PageLayout title={title} description={description}>
  <Fragment slot="head">
    <script data-cfasync="false" src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </Fragment>

  <section class="not-prose relative overflow-hidden rounded-[2rem] border border-slate-200 bg-linear-to-br from-white via-slate-50 to-amber-50 px-6 py-8 shadow-sm sm:px-8 lg:px-10 lg:py-10">
    <div class="absolute inset-x-0 top-0 h-40 bg-linear-to-r from-amber-100/70 via-transparent to-sky-100/70"></div>
    <div class="relative grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_23rem] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Bloomwood Solutions</p>
        <h1 class="mt-3 max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">
          Friendly tech support for homes and small business in Cairns.
        </h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-700">
          Reach us the way that suits you best. For quick questions, use chat or WhatsApp. For service work, call us or send a message and we’ll get back to you as soon as we can.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            class="inline-flex items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800"
            href="tel:0492991759"
          >
            Call 0492 991 759
          </a>
          <a
            class="inline-flex items-center justify-center rounded-xl bg-emerald-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700"
            href="https://wa.me/61492991759"
          >
            Message on WhatsApp
          </a>
          <a
            class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50"
            href="https://tawk.to/chat/68a2f3cfd8c4f119281983d9/1j2u8gole"
          >
            Open live chat
          </a>
          <a
            class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50"
            href="/solutions/bookings/"
          >
            Book a service
          </a>
        </div>

        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/80 bg-white/80 p-4 shadow-sm backdrop-blur">
            <p class="text-sm font-semibold text-slate-500">Best for</p>
            <p class="mt-2 text-base font-semibold text-slate-900">Urgent help</p>
            <p class="mt-1 text-sm leading-6 text-slate-600">Call or WhatsApp when you need support quickly.</p>
          </div>
          <div class="rounded-2xl border border-white/80 bg-white/80 p-4 shadow-sm backdrop-blur">
            <p class="text-sm font-semibold text-slate-500">Usually used for</p>
            <p class="mt-2 text-base font-semibold text-slate-900">Bookings and quotes</p>
            <p class="mt-1 text-sm leading-6 text-slate-600">Use the form for new jobs, estimates, or follow-up questions.</p>
          </div>
          <div class="rounded-2xl border border-white/80 bg-white/80 p-4 shadow-sm backdrop-blur">
            <p class="text-sm font-semibold text-slate-500">Service area</p>
            <p class="mt-2 text-base font-semibold text-slate-900">Cairns region</p>
            <p class="mt-1 text-sm leading-6 text-slate-600">Onsite and remote help for homes and small businesses.</p>
          </div>
        </div>
      </div>

      <aside class="rounded-[1.75rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-xl shadow-slate-950/10">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-300">Direct contact</p>
        <div class="mt-6 space-y-5">
          <div>
            <p class="text-sm text-slate-300">Phone</p>
            <a class="mt-1 block text-xl font-semibold text-white hover:text-amber-200" href="tel:0492991759">
              0492 991 759
            </a>
          </div>
          <div>
            <p class="text-sm text-slate-300">Email</p>
            <a class="mt-1 block text-xl font-semibold text-white hover:text-amber-200" href="mailto:help@bloomwood.com.au">
              help@bloomwood.com.au
            </a>
          </div>
          <div>
            <p class="text-sm text-slate-300">Location</p>
            <p class="mt-1 text-base leading-7 text-slate-100">7 Hook Close, Brinsmead, QLD 4870</p>
          </div>
        </div>

        <div class="mt-6 rounded-2xl bg-white/10 p-4">
          <p class="text-sm font-semibold text-white">Need a quick answer?</p>
          <p class="mt-2 text-sm leading-6 text-slate-200">
            If you already know what you need, booking online is often the fastest path.
          </p>
          <a
            class="mt-4 inline-flex items-center justify-center rounded-xl bg-white px-4 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-slate-100"
            href="/solutions/bookings/"
          >
            View booking options
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="not-prose mt-10 grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
    <div class="space-y-6">
      <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Send a message</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">Tell us what you need help with.</h2>
        <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">
          Share a few details and we’ll point you in the right direction. The more context you provide, the faster we can help.
        </p>

        <div id="contact-success" class="mt-5 hidden rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-900">
          Thanks. We’ve received your message and will get back to you shortly.
        </div>

        <script data-cfasync="false">
          (function () {
            try {
              var params = new URLSearchParams(window.location.search);
              if (params.get('sent') === '1') {
                var el = document.getElementById('contact-success');
                if (el) {
                  el.classList.remove('hidden');
                  try { el.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) { el.scrollIntoView(); }
                }
              }
            } catch (e) {}
          })();
        </script>

        <form class="mt-6 space-y-5" method="post" action="/api/contact">
          <input type="hidden" name="redirect" value="/solutions/bloomwood-solutions-contact-us/?sent=1" />

          <div style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;">
            <label for="company">Company</label>
            <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="space-y-2">
              <label for="name" class="text-sm font-medium text-slate-800">Name</label>
              <input
                name="name"
                type="text"
                id="name"
                required
                class="flex h-12 w-full rounded-xl border border-slate-300 bg-white px-4 text-sm text-slate-900 placeholder:text-slate-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-900 focus-visible:ring-offset-2"
                placeholder="Your name"
              />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-sm font-medium text-slate-800">Email address</label>
              <input
                name="email"
                type="email"
                id="email"
                required
                class="flex h-12 w-full rounded-xl border border-slate-300 bg-white px-4 text-sm text-slate-900 placeholder:text-slate-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-900 focus-visible:ring-offset-2"
                placeholder="name@example.com"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label for="message" class="text-sm font-medium text-slate-800">How can we help?</label>
            <textarea
              name="message"
              id="message"
              required
              class="flex min-h-36 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-900 focus-visible:ring-offset-2"
              placeholder="A short description of the issue, the device or service involved, and whether you need onsite or remote help."
            ></textarea>
          </div>

          <label class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
            <input
              name="newsletter"
              type="checkbox"
              id="newsletter"
              class="mt-1 h-4 w-4 shrink-0 rounded-sm border border-slate-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-900 focus-visible:ring-offset-2"
            />
            <span class="text-sm leading-6 text-slate-700">
              Send me occasional updates and practical tips by email. We keep it light, no more than once per month.
            </span>
          </label>

          <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
            <p class="text-sm font-medium text-slate-800">Quick check before sending</p>
            <p class="mt-1 text-sm leading-6 text-slate-600">
              Please confirm you’re human so we can keep spam out of the queue.
            </p>
            <div class="mt-3 cf-turnstile" data-sitekey="0x4AAAAAAC0DUFBV-rkbsjNy"></div>
          </div>

          <div class="flex flex-wrap items-center gap-4">
            <button
              type="submit"
              class="inline-flex min-h-12 items-center justify-center rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
            >
              Send message
            </button>
            <p class="text-sm leading-6 text-slate-500">
              Prefer not to use the form? Email
              <a class="font-semibold text-slate-900 underline decoration-slate-300 underline-offset-4 hover:decoration-slate-900" href="mailto:help@bloomwood.com.au">help@bloomwood.com.au</a>
              instead.
            </p>
          </div>
        </form>
      </div>
    </div>

    <div class="space-y-6">
      <section class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">What happens next</p>
        <ul class="mt-4 space-y-4 text-sm leading-6 text-slate-700">
          <li class="rounded-2xl bg-slate-50 px-4 py-3"><span class="font-semibold text-slate-900">1.</span> We review your message and work out the best next step.</li>
          <li class="rounded-2xl bg-slate-50 px-4 py-3"><span class="font-semibold text-slate-900">2.</span> If it looks urgent, calling or WhatsApp is still the fastest way to reach us.</li>
          <li class="rounded-2xl bg-slate-50 px-4 py-3"><span class="font-semibold text-slate-900">3.</span> If you already know the service you need, you can book online right away.</li>
        </ul>
      </section>

      <section class="rounded-[1.75rem] border border-slate-200 bg-linear-to-br from-slate-900 to-slate-800 p-6 text-white shadow-sm sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-300">Helpful links</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight">Need a bit more detail first?</h2>
        <p class="mt-3 text-sm leading-7 text-slate-200">
          If you’re comparing options, these pages can help before you reach out.
        </p>
        <div class="mt-5 grid gap-3">
          <a class="rounded-2xl border border-white/15 bg-white/5 px-4 py-4 transition hover:bg-white/10" href="/solutions/about/faq/">
            <span class="block text-base font-semibold text-white">Read the FAQ</span>
            <span class="mt-1 block text-sm leading-6 text-slate-300">Answers to common questions about services, coverage, and support.</span>
          </a>
          <a class="rounded-2xl border border-white/15 bg-white/5 px-4 py-4 transition hover:bg-white/10" href="/solutions/bookings/">
            <span class="block text-base font-semibold text-white">Browse booking options</span>
            <span class="mt-1 block text-sm leading-6 text-slate-300">Jump straight to onsite, remote, or quick-chat bookings.</span>
          </a>
          <a class="rounded-2xl border border-white/15 bg-white/5 px-4 py-4 transition hover:bg-white/10" href="/solutions/bookings/service-area/">
            <span class="block text-base font-semibold text-white">Check the service area</span>
            <span class="mt-1 block text-sm leading-6 text-slate-300">See where onsite support is available across the region.</span>
          </a>
        </div>
      </section>
    </div>
  </section>

  <div class="h-24 md:hidden" aria-hidden="true"></div>

  <div class="not-prose fixed inset-x-0 bottom-4 z-20 px-4 md:hidden">
    <div class="mx-auto grid max-w-sm grid-cols-2 gap-3 rounded-2xl border border-slate-200 bg-white/95 p-3 shadow-xl backdrop-blur">
      <a
        class="inline-flex min-h-12 items-center justify-center rounded-xl bg-slate-950 px-4 text-sm font-semibold text-white transition hover:bg-slate-800"
        href="tel:0492991759"
      >
        Call now
      </a>
      <a
        class="inline-flex min-h-12 items-center justify-center rounded-xl bg-emerald-600 px-4 text-sm font-semibold text-white transition hover:bg-emerald-700"
        href="https://wa.me/61492991759"
      >
        WhatsApp
      </a>
    </div>
  </div>
</PageLayout>
