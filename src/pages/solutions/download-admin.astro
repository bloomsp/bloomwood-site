---
import PageLayout from '../../layouts/PageLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

const accessKey = env.DOWNLOAD_ADMIN_KEY;
const providedKey = Astro.url.searchParams.get('key')?.trim() ?? '';
const isAuthorized = Boolean(accessKey) && providedKey === accessKey;
---

<PageLayout title="Download admin helper" description="Internal helper for Bloomwood client download issuance">
  <section class="space-y-8">
    {isAuthorized ? (
      <>
        <div class="rounded-2xl border border-amber-300 bg-amber-50 p-6 text-amber-950">
          <h1 class="text-3xl font-semibold tracking-tight">Client download admin helper</h1>
          <p class="mt-3 text-sm leading-6">
            Internal helper only. This page does not upload files or write to D1 directly. It helps you prepare a
            manifest and copy the exact CLI commands for the secure download workflow.
          </p>
        </div>

        <form id="download-admin-form" class="grid gap-6 lg:grid-cols-2 not-prose">
      <div class="space-y-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Job details</h2>

        <label class="block text-sm font-medium text-slate-700">
          Job reference
          <input id="jobReference" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" value="2026-0042" />
        </label>

        <label class="block text-sm font-medium text-slate-700">
          Client name
          <input id="clientName" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" value="Jane Citizen" />
        </label>

        <label class="block text-sm font-medium text-slate-700">
          Client email
          <input id="clientEmail" type="email" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" value="jane@example.com" />
        </label>

        <label class="block text-sm font-medium text-slate-700">
          Notes
          <textarea id="notes" class="mt-1 min-h-24 w-full rounded-lg border border-slate-300 px-3 py-2">Recovered family photos</textarea>
        </label>

        <label class="block text-sm font-medium text-slate-700">
          Expiry days
          <input id="expiresDays" type="number" min="1" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" value="7" />
        </label>

        <label class="block text-sm font-medium text-slate-700">
          R2 bucket
          <input id="bucket" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" value="bloomwood-client-downloads" />
        </label>

        <label class="block text-sm font-medium text-slate-700">
          Local source folder
          <input id="source" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" value="./recovery-2026-0042" />
        </label>

        <label class="block text-sm font-medium text-slate-700">
          Manifest output path
          <input id="manifestOut" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" value="./client-download-2026-0042.json" />
        </label>
      </div>

      <div class="space-y-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Files</h2>
        <p class="text-sm text-slate-600">
          Enter one file per line as: <code>displayName|r2Key|contentType|sizeBytes</code>
        </p>
        <textarea id="files" class="min-h-40 w-full rounded-lg border border-slate-300 px-3 py-2 font-mono text-sm">Recovered Photos.zip|recoveries/2026-0042/Recovered Photos.zip|application/zip|1234567</textarea>

        <div class="flex flex-wrap gap-3">
          <button type="button" id="generateManifest" class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">
            Generate manifest
          </button>
          <button type="button" id="copyManifest" class="rounded-lg bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700">
            Copy manifest
          </button>
          <button type="button" id="copyCommands" class="rounded-lg bg-emerald-700 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-600">
            Copy commands
          </button>
        </div>
      </div>
        </form>

        <div class="grid gap-6 lg:grid-cols-2 not-prose">
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Manifest preview</h2>
        <pre id="manifestPreview" class="mt-4 overflow-x-auto rounded-xl bg-slate-950 p-4 text-sm text-slate-100"></pre>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">CLI commands</h2>
        <pre id="commandPreview" class="mt-4 overflow-x-auto rounded-xl bg-slate-950 p-4 text-sm text-slate-100"></pre>
      </section>
        </div>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm not-prose">
      <h2 class="text-xl font-semibold text-slate-900">Recommended workflow</h2>
      <ol class="mt-4 list-decimal space-y-2 pl-5 text-slate-700">
        <li>Upload the local recovery folder with <code>downloads:upload</code>.</li>
        <li>Issue the expiring link with <code>downloads:issue</code>.</li>
        <li>Send the printed Bloomwood download URL to the client.</li>
        <li>Keep the raw URL private, regenerate instead of reusing old links.</li>
      </ol>
        </section>
      </>
    ) : (
      <div class="rounded-2xl border border-rose-300 bg-rose-50 p-6 text-rose-950">
        <h1 class="text-3xl font-semibold tracking-tight">Restricted internal page</h1>
        <p class="mt-3 text-sm leading-6">
          This helper is intended for internal Bloomwood operations only.
        </p>
        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm">
          <li>Set the Cloudflare secret <code>DOWNLOAD_ADMIN_KEY</code>.</li>
          <li>Open this page with <code>?key=&lt;your-secret&gt;</code>.</li>
          <li>Consider protecting the route further with Cloudflare Access before public deployment.</li>
        </ul>
      </div>
    )}
  </section>

  {isAuthorized ? <script is:inline>
    const byId = (id) => document.getElementById(id);

    function shellQuote(value) {
      return JSON.stringify(String(value));
    }

    function parseFiles(text) {
      return String(text)
        .split(/\n+/)
        .map((line) => line.trim())
        .filter(Boolean)
        .map((line) => {
          const [displayName, r2Key, contentType, sizeBytes] = line.split('|').map((part) => part?.trim() ?? '');
          return {
            displayName,
            r2Key,
            contentType: contentType || undefined,
            sizeBytes: sizeBytes ? Number(sizeBytes) : undefined,
          };
        })
        .filter((file) => file.displayName && file.r2Key);
    }

    function buildState() {
      return {
        jobReference: byId('jobReference').value.trim(),
        clientName: byId('clientName').value.trim(),
        clientEmail: byId('clientEmail').value.trim(),
        notes: byId('notes').value.trim(),
        expiresDays: Number(byId('expiresDays').value || '7'),
        bucket: byId('bucket').value.trim(),
        source: byId('source').value.trim(),
        manifestOut: byId('manifestOut').value.trim(),
        files: parseFiles(byId('files').value),
      };
    }

    function buildManifest(state) {
      return {
        jobReference: state.jobReference,
        clientName: state.clientName,
        clientEmail: state.clientEmail || undefined,
        notes: state.notes || undefined,
        expiresDays: state.expiresDays,
        files: state.files,
      };
    }

    function buildCommands(state) {
      const upload = [
        'npm run downloads:upload -- \\\n',
        `  --source ${shellQuote(state.source)} \\\n`,
        `  --bucket ${shellQuote(state.bucket)} \\\n`,
        `  --job-reference ${shellQuote(state.jobReference)} \\\n`,
        `  --client-name ${shellQuote(state.clientName)} \\\n`,
        state.clientEmail ? `  --client-email ${shellQuote(state.clientEmail)} \\\n` : '',
        state.notes ? `  --notes ${shellQuote(state.notes)} \\\n` : '',
        `  --manifest-out ${shellQuote(state.manifestOut)} \\\n`,
        '  --remote',
      ].join('');

      const issue = [
        'npm run downloads:issue -- \\\n',
        `  --manifest ${shellQuote(state.manifestOut)} \\\n`,
        '  --db CLIENT_DOWNLOADS_DB \\\n',
        '  --remote',
      ].join('');

      return `${upload}\n\n${issue}`;
    }

    function render() {
      const state = buildState();
      byId('manifestPreview').textContent = JSON.stringify(buildManifest(state), null, 2);
      byId('commandPreview').textContent = buildCommands(state);
    }

    async function copyText(text) {
      await navigator.clipboard.writeText(text);
    }

    byId('generateManifest').addEventListener('click', render);
    byId('copyManifest').addEventListener('click', async () => {
      await copyText(byId('manifestPreview').textContent || '');
    });
    byId('copyCommands').addEventListener('click', async () => {
      await copyText(byId('commandPreview').textContent || '');
    });

    for (const id of ['jobReference', 'clientName', 'clientEmail', 'notes', 'expiresDays', 'bucket', 'source', 'manifestOut', 'files']) {
      byId(id).addEventListener('input', render);
    }

    render();
  </script> : null}
</PageLayout>
