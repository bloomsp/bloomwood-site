---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect('/crm/login?next=%2Fcrm%2Fservice-packs%2Fnew');
}

const supabase = (Astro.locals as any).supabase;
let formError: string | null = null;

const { data: clients } = supabase
  ? await supabase.from('clients').select('id, display_name').order('display_name', { ascending: true })
  : { data: [] as any[] };
const { data: serviceTypes } = supabase
  ? await supabase.from('service_types').select('id, name, item_code, pack_hours, pack_price').eq('is_service_pack', true).order('sort_order', { ascending: true })
  : { data: [] as any[] };

const selectedClientId = String(Astro.url.searchParams.get('client_id') ?? '');
const selectedServiceTypeId = String(Astro.url.searchParams.get('service_type_id') ?? '');
const selectedServiceType = (serviceTypes ?? []).find((item: any) => item.id === selectedServiceTypeId) ?? null;
const initialHoursPurchased = Astro.url.searchParams.get('hours_purchased') ?? (selectedServiceType?.pack_hours != null ? String(selectedServiceType.pack_hours) : '');
const initialMinutesPurchased = Astro.url.searchParams.get('minutes_purchased') ?? (selectedServiceType?.pack_hours != null ? String(Math.round(Number(selectedServiceType.pack_hours) * 60)) : '');
const initialPurchasePrice = Astro.url.searchParams.get('purchase_price') ?? (selectedServiceType?.pack_price != null ? String(selectedServiceType.pack_price) : '');
const initialPurchaseDate = Astro.url.searchParams.get('purchase_date') ?? new Date().toISOString().slice(0, 10);

function addTwelveMonths(dateString: string | null) {
  if (!dateString) return null;
  const date = new Date(`${dateString}T00:00:00`);
  if (Number.isNaN(date.getTime())) return null;
  date.setMonth(date.getMonth() + 12);
  return date.toISOString().slice(0, 10);
}

const initialExpiryDate = Astro.url.searchParams.get('expiry_date') ?? addTwelveMonths(initialPurchaseDate);

if (Astro.request.method === 'POST') {
  if (!supabase) {
    formError = 'Supabase is not configured for this environment yet.';
  } else {
    const formData = await Astro.request.formData();
    const serviceTypeId = String(formData.get('service_type_id') ?? '').trim();
    const serviceType = (serviceTypes ?? []).find((item: any) => item.id === serviceTypeId);
    const hoursPurchased = Number(formData.get('hours_purchased') ?? serviceType?.pack_hours ?? 0) || 0;
    const minutesPurchased = Number(formData.get('minutes_purchased') ?? Math.round(hoursPurchased * 60)) || 0;
    const payload = {
      client_id: String(formData.get('client_id') ?? '').trim(),
      service_type_id: serviceTypeId,
      hours_purchased: hoursPurchased,
      minutes_purchased: minutesPurchased,
      minutes_used: 0,
      purchase_price: Number(formData.get('purchase_price') ?? serviceType?.pack_price ?? 0) || 0,
      purchase_date: String(formData.get('purchase_date') ?? '').trim() || null,
      expiry_date: String(formData.get('expiry_date') ?? '').trim() || null,
      status: String(formData.get('status') ?? 'active'),
      notes: String(formData.get('notes') ?? '').trim() || null,
    };
    payload.expiry_date = payload.expiry_date || addTwelveMonths(payload.purchase_date);
    if (!payload.client_id || !payload.service_type_id) {
      formError = 'Client and service pack are required.';
    } else {
      const { error } = await supabase.from('service_packs').insert(payload);
      if (error) {
        console.error('Failed to create service pack', error);
        formError = error.message;
      } else {
        return Astro.redirect(`/crm/clients/${payload.client_id}`);
      }
    }
  }
}
---

<CrmLayout title="New service pack" description="Create Bloomwood CRM service pack">
  <section class="mb-6 flex items-center justify-between gap-3">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Service packs</p>
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Add service pack</h2>
    </div>
    <a href="/crm/clients" class="rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-slate-100">Back</a>
  </section>

  {formError ? <section class="mb-6 rounded-2xl border border-rose-300 bg-rose-50 p-4 text-sm text-rose-950">{formError}</section> : null}

  <form method="post" class="space-y-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <section class="grid gap-4 md:grid-cols-2">
      <label class="block text-sm font-medium text-slate-700">
        Client
        <select name="client_id" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
          <option value="">Select client</option>
          {(clients ?? []).map((client: any) => <option value={client.id} selected={selectedClientId === client.id}>{client.display_name}</option>)}
        </select>
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Service pack
        <select id="service-pack-type" name="service_type_id" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
          <option value="">Select pack</option>
          {(serviceTypes ?? []).map((serviceType: any) => <option value={serviceType.id} data-pack-hours={serviceType.pack_hours ?? ''} data-pack-price={serviceType.pack_price ?? ''} selected={selectedServiceTypeId === serviceType.id}>{serviceType.name} ({serviceType.item_code})</option>)}
        </select>
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Hours purchased
        <input id="service-pack-hours" type="number" min="0" step="0.01" name="hours_purchased" value={initialHoursPurchased} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Minutes purchased
        <input id="service-pack-minutes" type="number" min="0" name="minutes_purchased" value={initialMinutesPurchased} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <div class="block text-sm font-medium text-slate-700">
        Minutes used
        <input type="number" min="0" value="0" disabled class="mt-1 w-full rounded-lg border border-slate-300 bg-slate-50 px-3 py-2 text-slate-500" />
        <span class="mt-1 block text-xs font-normal text-slate-500">Calculated from completed pack-linked tasks.</span>
      </div>
      <label class="block text-sm font-medium text-slate-700">
        Purchase price
        <input id="service-pack-price" type="number" min="0" step="0.01" name="purchase_price" value={initialPurchasePrice} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Purchase date
        <input id="service-pack-purchase-date" type="date" name="purchase_date" value={initialPurchaseDate} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Expiry date
        <input id="service-pack-expiry-date" type="date" name="expiry_date" value={initialExpiryDate ?? ''} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Status
        <select name="status" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
          <option value="active">Active</option>
          <option value="used_up">Used up</option>
          <option value="expired">Expired</option>
          <option value="cancelled">Cancelled</option>
        </select>
      </label>
      <label class="block text-sm font-medium text-slate-700 md:col-span-2">
        Notes
        <textarea name="notes" rows="3" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2"></textarea>
      </label>
    </section>
    <div class="flex justify-end gap-3">
      <a href="/crm/clients" class="rounded-lg px-4 py-2 text-sm text-slate-700 hover:bg-slate-100">Cancel</a>
      <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Create service pack</button>
    </div>
  </form>

  <script is:inline>
    const packSelect = document.getElementById('service-pack-type');
    const hoursInput = document.getElementById('service-pack-hours');
    const minutesInput = document.getElementById('service-pack-minutes');
    const priceInput = document.getElementById('service-pack-price');
    const purchaseDateInput = document.getElementById('service-pack-purchase-date');
    const expiryDateInput = document.getElementById('service-pack-expiry-date');

    function addTwelveMonths(dateString) {
      if (!dateString) return '';
      const date = new Date(`${dateString}T00:00:00`);
      if (Number.isNaN(date.getTime())) return '';
      date.setMonth(date.getMonth() + 12);
      return date.toISOString().slice(0, 10);
    }

    function applyPackDefaults() {
      const selectedOption = packSelect?.selectedOptions?.[0];
      if (!selectedOption) return;
      const hours = selectedOption.getAttribute('data-pack-hours');
      const price = selectedOption.getAttribute('data-pack-price');
      if (hoursInput && hours) hoursInput.value = hours;
      if (minutesInput && hours) minutesInput.value = String(Math.round(Number(hours) * 60));
      if (priceInput && price) priceInput.value = price;
    }

    packSelect?.addEventListener('change', applyPackDefaults);
    purchaseDateInput?.addEventListener('change', () => {
      if (expiryDateInput && purchaseDateInput?.value) {
        expiryDateInput.value = addTwelveMonths(purchaseDateInput.value);
      }
    });
  </script>
</CrmLayout>
