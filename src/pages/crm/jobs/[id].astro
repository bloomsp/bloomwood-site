---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect(`/crm/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const { id } = Astro.params;
const supabase = (Astro.locals as any).supabase;

let job: any = null;
let notes: any[] = [];
let tasks: any[] = [];
let fileDeliveries: any[] = [];
let packUsage: any[] = [];
let loadError: string | null = null;

function roundBillableMinutes(minutes: number, increment: number | null) {
  if (!increment || increment <= 0) return minutes;
  return Math.ceil(minutes / increment) * increment;
}

function getCalculatedAmount(minutes: number, hourlyRate: number | null, increment: number | null) {
  if (!hourlyRate || minutes <= 0) return 0;
  const roundedMinutes = roundBillableMinutes(minutes, increment);
  return (roundedMinutes / 60) * hourlyRate;
}

if (Astro.request.method === 'POST' && supabase) {
  const formData = await Astro.request.formData();
  const action = String(formData.get('action') ?? '');

  if (action === 'add-note') {
    const payload = {
      job_id: id,
      note_type: String(formData.get('note_type') ?? 'internal'),
      body: String(formData.get('body') ?? '').trim(),
    };

    if (!payload.body) {
      loadError = 'Note body is required.';
    } else {
      const { error } = await supabase.from('job_notes').insert(payload);
      if (error) {
        console.error('Failed to create job note', error);
        loadError = error.message;
      } else {
        return Astro.redirect(`/crm/jobs/${id}`);
      }
    }
  }

  if (action === 'add-task') {
    if (job?.status === 'completed') {
      loadError = 'No more tasks can be added to a completed job.';
    } else {
    const timeHours = Number(formData.get('time_hours') ?? 0) || 0;
    const timeMinutes = Number(formData.get('time_minutes') ?? 0) || 0;
    const payload = {
      job_id: id,
      client_id: String(formData.get('client_id') ?? '').trim() || null,
      service_pack_id: String(formData.get('service_pack_id') ?? '').trim() || null,
      title: String(formData.get('title') ?? '').trim(),
      details: String(formData.get('details') ?? '').trim() || null,
      status: String(formData.get('status') ?? 'open'),
      due_at: String(formData.get('due_at') ?? '').trim() || null,
      time_taken_minutes: (timeHours * 60) + timeMinutes,
    };

    if (!payload.title) {
      loadError = 'Task title is required.';
    } else {
      const { error } = await supabase.from('tasks').insert(payload);
      if (error) {
        console.error('Failed to create job task', error);
        loadError = error.message;
      } else {
        return Astro.redirect(`/crm/jobs/${id}`);
      }
    }
    }
  }

  if (action === 'complete-task') {
    const taskId = String(formData.get('task_id') ?? '').trim();
    const timeHours = Number(formData.get('time_hours') ?? 0) || 0;
    const timeMinutes = Number(formData.get('time_minutes') ?? 0) || 0;
    const servicePackId = String(formData.get('service_pack_id') ?? '').trim() || null;
    const totalMinutes = (timeHours * 60) + timeMinutes;
    if (!taskId) {
      loadError = 'Task id is required.';
    } else {
      const { error } = await supabase
        .from('tasks')
        .update({
          status: 'done',
          completed_at: new Date().toISOString(),
          time_taken_minutes: totalMinutes,
          service_pack_id: servicePackId,
        })
        .eq('id', taskId)
        .eq('job_id', id);
      if (error) {
        console.error('Failed to complete job task', error);
        loadError = error.message;
      } else {
        const nextBillableMinutes = Number(job?.billable_minutes ?? 0) + totalMinutes;
        const nextBillableAmount = Number(job?.calculated_billable_amount ?? 0) + getCalculatedAmount(
          totalMinutes,
          Number(job?.hourly_rate_snapshot ?? 0),
          Number(job?.billing_increment_minutes_snapshot ?? 0) || null,
        );

        await supabase
          .from('jobs')
          .update({
            billable_minutes: nextBillableMinutes,
            calculated_billable_amount: nextBillableAmount,
          })
          .eq('id', id);

        return Astro.redirect(`/crm/jobs/${id}`);
      }
    }
  }

  if (action === 'add-file-delivery') {
    const payload = {
      job_id: id,
      delivery_type: String(formData.get('delivery_type') ?? 'download_link'),
      status: String(formData.get('status') ?? 'pending'),
      download_job_id: String(formData.get('download_job_id') ?? '').trim() || null,
      notes: String(formData.get('notes') ?? '').trim() || null,
    };

    const { error } = await supabase.from('file_deliveries').insert(payload);
    if (error) {
      console.error('Failed to create file delivery', error);
      loadError = error.message;
    } else {
      return Astro.redirect(`/crm/jobs/${id}`);
    }
  }

  if (action === 'add-pack-usage') {
    const servicePackId = String(formData.get('service_pack_id') ?? '').trim();
    const minutesApplied = Number(formData.get('minutes_applied') ?? 0) || 0;
    const notesText = String(formData.get('notes') ?? '').trim() || null;

    if (!servicePackId || minutesApplied <= 0) {
      loadError = 'Choose a service pack and enter minutes applied.';
    } else {
      const { error } = await supabase.from('service_pack_usage').insert({
        service_pack_id: servicePackId,
        job_id: id,
        minutes_applied: minutesApplied,
        notes: notesText,
      });

      if (error) {
        console.error('Failed to create service pack usage', error);
        loadError = error.message;
      } else {
        const { data: servicePack } = await supabase
          .from('service_packs')
          .select('minutes_used')
          .eq('id', servicePackId)
          .single();

        if (servicePack) {
          const purchasedMinutes = Number(servicePack.minutes_purchased ?? 0) || Math.round(Number((servicePack as any).hours_purchased ?? 0) * 60);
          const newMinutesUsed = Number(servicePack.minutes_used ?? 0) + minutesApplied;
          const { data: fullServicePack } = await supabase
            .from('service_packs')
            .select('minutes_purchased, hours_purchased')
            .eq('id', servicePackId)
            .single();

          const totalPurchased = fullServicePack
            ? (Number(fullServicePack.minutes_purchased ?? 0) || Math.round(Number(fullServicePack.hours_purchased ?? 0) * 60))
            : purchasedMinutes;
          const nextStatus = newMinutesUsed >= totalPurchased
            ? 'used_up'
            : 'active';

          await supabase
            .from('service_packs')
            .update({ minutes_used: newMinutesUsed, status: nextStatus })
            .eq('id', servicePackId);
        }

        return Astro.redirect(`/crm/jobs/${id}`);
      }
    }
  }
}

if (!supabase) {
  loadError = 'Supabase is not configured for this environment yet.';
} else {
  const [jobResult, notesResult, tasksResult, fileDeliveriesResult, packUsageResult] = await Promise.all([
    supabase
      .from('jobs')
      .select('*, client:clients(id, display_name, business_name, email, phone), service_type:service_types(name, item_code)')
      .eq('id', id)
      .single(),
    supabase.from('job_notes').select('id, note_type, body, created_at').eq('job_id', id).order('created_at', { ascending: false }),
    supabase.from('tasks').select('id, title, details, status, due_at, completed_at, time_taken_minutes, service_pack_id').eq('job_id', id).order('due_at', { ascending: true }),
    supabase.from('file_deliveries').select('id, delivery_type, status, download_job_id, notes, updated_at').eq('job_id', id).order('updated_at', { ascending: false }),
    supabase
      .from('service_pack_usage')
      .select('id, minutes_applied, notes, created_at, service_pack:service_packs(id, minutes_purchased, minutes_used, status, service_type:service_types(name, item_code))')
      .eq('job_id', id)
      .order('created_at', { ascending: false }),
  ]);

  if (jobResult.error || notesResult.error || tasksResult.error || fileDeliveriesResult.error || packUsageResult.error) {
    console.error('Failed to load job detail', jobResult.error || notesResult.error || tasksResult.error || fileDeliveriesResult.error || packUsageResult.error);
    loadError = 'Could not load this job yet. The latest CRM migration may still need to be applied.';
  } else {
    job = jobResult.data;
    notes = notesResult.data ?? [];
    tasks = tasksResult.data ?? [];
    fileDeliveries = fileDeliveriesResult.data ?? [];
    packUsage = (packUsageResult.data ?? []).map((usage) => ({
      ...usage,
      minutes_remaining: usage.service_pack
        ? Math.max(0, Number(usage.service_pack.minutes_purchased ?? 0) - Number(usage.service_pack.minutes_used ?? 0))
        : 0,
    }));
  }
}

let availableServicePacks: any[] = [];
if (supabase && job?.client?.id) {
  const { data } = await supabase
    .from('service_packs')
    .select('id, minutes_purchased, hours_purchased, minutes_used, status, service_type:service_types(name, item_code)')
    .eq('client_id', job.client.id)
    .eq('status', 'active')
    .order('purchase_date', { ascending: false });

  availableServicePacks = (data ?? []).map((pack) => ({
    ...pack,
    minutes_remaining: Math.max(0, (Number(pack.minutes_purchased ?? 0) || Math.round(Number(pack.hours_purchased ?? 0) * 60)) - Number(pack.minutes_used ?? 0)),
  })).filter((pack) => pack.minutes_remaining > 0);
}

function formatHours(minutes: number) {
  return (minutes / 60).toFixed(2);
}
---

<CrmLayout title="Job detail" description="Bloomwood CRM job detail">
  {loadError ? (
    <section class="rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-950">
      {loadError}
    </section>
  ) : !job ? (
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm text-slate-600">Job not found.</p>
    </section>
  ) : (
    <>
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Job</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">{job.title}</h2>
            <div class="mt-2 text-sm text-slate-600">{job.job_reference}</div>
            {job.client?.display_name ? <div class="mt-3 text-sm text-slate-600">Client: <a class="font-medium text-sky-700 hover:underline" href={`/crm/clients/${job.client.id}`}>{job.client.display_name}</a></div> : null}
            {job.service_type?.name ? <div class="text-sm text-slate-600">Service: {job.service_type.name}{job.service_type.item_code ? ` (${job.service_type.item_code})` : ''}</div> : null}
          </div>
          <div class="grid gap-3 md:w-[24rem]">
            <div class="flex justify-end gap-2">
              <a href={`/crm/jobs/${id}/edit`} class="rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Edit job</a>
            </div>
            <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Status</div>
              <div class="mt-1 text-lg font-semibold text-slate-900">{job.status}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Priority</div>
              <div class="mt-1 text-lg font-semibold text-slate-900">{job.priority}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Billable</div>
              <div class="mt-1 text-lg font-semibold text-slate-900">${Number(job.calculated_billable_amount ?? 0).toFixed(2)}</div>
              <div class="mt-1 text-xs normal-case tracking-normal text-slate-500">From job billable minutes and completed task time.</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Invoice</div>
              <div class="mt-1 text-sm font-semibold text-slate-900">{job.invoice_number ?? 'Not set'}</div>
            </div>
            </div>
          </div>
        </div>
      </section>

      <section class="mt-6 grid gap-6 lg:grid-cols-[1.4fr_1fr]">
        <div class="space-y-6">
          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Work details</h3>
            <dl class="mt-4 grid gap-4 md:grid-cols-2">
              <div>
                <dt class="text-xs uppercase tracking-wide text-slate-500">Category</dt>
                <dd class="mt-1 text-sm text-slate-900">{job.category}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wide text-slate-500">Device type</dt>
                <dd class="mt-1 text-sm text-slate-900">{job.device_type ?? '—'}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wide text-slate-500">Serial number</dt>
                <dd class="mt-1 text-sm text-slate-900">{job.serial_number ?? '—'}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wide text-slate-500">Billable minutes</dt>
                <dd class="mt-1 text-sm text-slate-900">{job.billable_minutes ?? 0}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wide text-slate-500">Hourly rate snapshot</dt>
                <dd class="mt-1 text-sm text-slate-900">{job.hourly_rate_snapshot ? `$${Number(job.hourly_rate_snapshot).toFixed(2)}` : '—'}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wide text-slate-500">Billing increment</dt>
                <dd class="mt-1 text-sm text-slate-900">{job.billing_increment_minutes_snapshot ? `${job.billing_increment_minutes_snapshot} min` : '—'}</dd>
              </div>
              <div class="md:col-span-2">
                <dt class="text-xs uppercase tracking-wide text-slate-500">Intake details</dt>
                <dd class="mt-1 text-sm leading-6 text-slate-900">{job.intake_details ?? '—'}</dd>
              </div>
              <div class="md:col-span-2">
                <dt class="text-xs uppercase tracking-wide text-slate-500">Diagnosis</dt>
                <dd class="mt-1 text-sm leading-6 text-slate-900">{job.diagnosis ?? '—'}</dd>
              </div>
              <div class="md:col-span-2">
                <dt class="text-xs uppercase tracking-wide text-slate-500">Resolution summary</dt>
                <dd class="mt-1 text-sm leading-6 text-slate-900">{job.resolution_summary ?? '—'}</dd>
              </div>
            </dl>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Notes</h3>
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="add-note" />
              <div class="grid gap-3 md:grid-cols-[12rem_1fr_auto]">
                <select name="note_type" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="call">Call</option>
                  <option value="email">Email</option>
                  <option value="onsite">Onsite</option>
                  <option value="internal" selected>Internal</option>
                  <option value="recovery">Recovery</option>
                  <option value="delivery">Delivery</option>
                </select>
                <input name="body" placeholder="Add a quick note" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Add note</button>
              </div>
            </form>
            <div class="mt-4 space-y-3">
              {notes.length === 0 ? <p class="text-sm text-slate-600">No notes yet.</p> : null}
              {notes.map((note) => (
                <div class="rounded-xl border border-slate-200 p-4">
                  <div class="text-xs uppercase tracking-wide text-slate-500">{note.note_type} • {note.created_at}</div>
                  <p class="mt-2 text-sm leading-6 text-slate-700">{note.body}</p>
                </div>
              ))}
            </div>
          </section>
        </div>

        <div class="space-y-6">
          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Tasks</h3>
            {job.status !== 'completed' ? (
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="add-task" />
              <input type="hidden" name="client_id" value={job.client?.id ?? ''} />
              <div class="grid gap-3 md:grid-cols-2">
                <input name="title" placeholder="Task title" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Due date</span>
                  <input type="datetime-local" name="due_at" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                </label>
                <input name="details" placeholder="Task details" class="rounded-lg border border-slate-300 px-3 py-2 text-sm md:col-span-2" />
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Hours</span>
                  <select name="time_hours" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    {Array.from({ length: 9 }, (_, i) => <option value={i}>{i}</option>)}
                  </select>
                </label>
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Minutes</span>
                  <select name="time_minutes" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    {[0, 15, 30, 45].map((minute) => <option value={minute}>{minute}</option>)}
                  </select>
                </label>
                <label class="text-sm text-slate-700 md:col-span-2">
                  <span class="mb-1 block">Service pack</span>
                  <select name="service_pack_id" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    <option value="">No service pack</option>
                    {availableServicePacks.map((pack) => (
                      <option value={pack.id}>{pack.service_type?.name ?? 'Service pack'} ({formatHours(pack.minutes_remaining)} hrs remaining)</option>
                    ))}
                  </select>
                </label>
              </div>
              <div class="mt-3 flex justify-end">
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Add task</button>
              </div>
            </form>
            ) : (
              <p class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">This job is completed, so no more tasks can be added.</p>
            )}
            <div class="mt-4 space-y-3">
              {tasks.length === 0 ? <p class="text-sm text-slate-600">No tasks yet.</p> : null}
              {tasks.map((task) => (
                <div class="rounded-xl border border-slate-200 p-4">
                  <div class="text-sm font-semibold text-slate-900">{task.title}</div>
                  {task.details ? <div class="mt-1 text-sm text-slate-600">{task.details}</div> : null}
                  <div class="mt-2 flex items-center justify-between gap-3 text-xs uppercase tracking-wide text-slate-500">
                    <div>{task.status}{task.due_at ? ` • ${task.due_at}` : ''}{task.time_taken_minutes ? ` • ${formatHours(Number(task.time_taken_minutes))}h` : ''}</div>
                    {task.status === 'open' ? (
                      <form method="post">
                        <input type="hidden" name="action" value="complete-task" />
                        <input type="hidden" name="task_id" value={task.id} />
                        <div class="mt-2 grid gap-2">
                          <select name="time_hours" class="rounded-lg border border-slate-300 px-2 py-1 text-xs text-slate-700">
                            {Array.from({ length: 9 }, (_, i) => <option value={i}>{i}h</option>)}
                          </select>
                          <select name="time_minutes" class="rounded-lg border border-slate-300 px-2 py-1 text-xs text-slate-700">
                            {[0, 15, 30, 45].map((minute) => <option value={minute}>{minute}m</option>)}
                          </select>
                          <select name="service_pack_id" class="rounded-lg border border-slate-300 px-2 py-1 text-xs text-slate-700">
                            <option value="">No pack</option>
                            {availableServicePacks.map((pack) => (
                              <option value={pack.id}>{pack.service_type?.item_code ?? 'Pack'} ({formatHours(pack.minutes_remaining)}h)</option>
                            ))}
                          </select>
                          <button class="rounded-lg border border-slate-300 px-2 py-1 text-xs text-slate-700 hover:bg-slate-50">Mark done</button>
                        </div>
                      </form>
                    ) : null}
                  </div>
                </div>
              ))}
            </div>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Service-pack usage</h3>
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="add-pack-usage" />
              <div class="grid gap-3 md:grid-cols-2">
                <select name="service_pack_id" class="rounded-lg border border-slate-300 px-3 py-2 text-sm md:col-span-2">
                  <option value="">Select active service pack</option>
                  {availableServicePacks.map((pack) => (
                    <option value={pack.id}>{pack.service_type?.name ?? 'Service pack'} ({formatHours(pack.minutes_remaining)} hrs remaining)</option>
                  ))}
                </select>
                <input type="number" min="1" name="minutes_applied" placeholder="Minutes applied" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <input name="notes" placeholder="Usage notes" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
              </div>
              <div class="mt-3 flex justify-end">
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Add usage</button>
              </div>
            </form>
            <div class="mt-4 space-y-3">
              {packUsage.length === 0 ? <p class="text-sm text-slate-600">No service-pack usage recorded for this job yet.</p> : null}
              {packUsage.map((usage) => (
                <div class="rounded-xl border border-slate-200 p-4">
                  <div class="text-sm font-semibold text-slate-900">{usage.service_pack?.service_type?.name ?? 'Service pack'}</div>
                  <div class="mt-1 text-sm text-slate-600">Applied: {formatHours(Number(usage.minutes_applied ?? 0))} hrs</div>
                  <div class="text-sm text-slate-600">Remaining on pack: {formatHours(usage.minutes_remaining)} hrs</div>
                  {usage.notes ? <div class="mt-1 text-sm text-slate-600">{usage.notes}</div> : null}
                </div>
              ))}
            </div>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">File delivery</h3>
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="add-file-delivery" />
              <div class="grid gap-3 md:grid-cols-2">
                <select name="delivery_type" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="download_link">Download link</option>
                  <option value="usb">USB</option>
                  <option value="external_drive">External drive</option>
                  <option value="email">Email</option>
                </select>
                <select name="status" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="pending">Pending</option>
                  <option value="uploaded">Uploaded</option>
                  <option value="link_issued">Link issued</option>
                  <option value="delivered">Delivered</option>
                  <option value="expired">Expired</option>
                  <option value="revoked">Revoked</option>
                </select>
                <input name="download_job_id" placeholder="Download job id (optional)" class="rounded-lg border border-slate-300 px-3 py-2 text-sm md:col-span-2" />
                <input name="notes" placeholder="Delivery notes" class="rounded-lg border border-slate-300 px-3 py-2 text-sm md:col-span-2" />
              </div>
              <div class="mt-3 flex justify-end">
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Add delivery</button>
              </div>
            </form>
            <div class="mt-4 space-y-3">
              {fileDeliveries.length === 0 ? <p class="text-sm text-slate-600">No file delivery records yet.</p> : null}
              {fileDeliveries.map((delivery) => (
                <div class="rounded-xl border border-slate-200 p-4">
                  <div class="text-sm font-semibold text-slate-900">{delivery.delivery_type}</div>
                  <div class="mt-1 text-sm text-slate-600">Status: {delivery.status}</div>
                  {delivery.download_job_id ? <div class="text-sm text-slate-600">Download job: {delivery.download_job_id}</div> : null}
                  {delivery.notes ? <div class="mt-1 text-sm text-slate-600">{delivery.notes}</div> : null}
                </div>
              ))}
            </div>
          </section>
        </div>
      </section>
    </>
  )}
</CrmLayout>
