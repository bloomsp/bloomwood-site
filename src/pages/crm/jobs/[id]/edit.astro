---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect(`/crm/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const { id } = Astro.params;
const supabase = (Astro.locals as any).supabase;
let formError: string | null = null;

function minutesFromParts(hours: FormDataEntryValue | null, minutes: FormDataEntryValue | null) {
  return ((Number(hours ?? 0) || 0) * 60) + (Number(minutes ?? 0) || 0);
}

function splitMinutes(totalMinutes: number) {
  const safeMinutes = Math.max(0, Number(totalMinutes ?? 0) || 0);
  return {
    hours: Math.floor(safeMinutes / 60),
    minutes: safeMinutes % 60,
  };
}

function formatHours(minutes: number) {
  return (minutes / 60).toFixed(2);
}

const { data: job, error: jobError } = supabase
  ? await supabase.from('jobs').select('*').eq('id', id).single()
  : { data: null, error: new Error('Supabase is not configured for this environment yet.') };
const { data: clients } = supabase
  ? await supabase.from('clients').select('id, display_name').order('display_name', { ascending: true })
  : { data: [] as any[] };
const { data: serviceTypes } = supabase
  ? await supabase.from('service_types').select('id, name, item_code, hourly_rate, billing_increment_minutes').eq('billing_mode', 'hourly').order('sort_order', { ascending: true })
  : { data: [] as any[] };
const { data: taskRows } = supabase && job
  ? await supabase.from('tasks').select('billable_minutes, non_billable_minutes').eq('job_id', id)
  : { data: [] as any[] };

if (jobError || !job) {
  formError = jobError instanceof Error ? jobError.message : 'Job not found.';
}

if (Astro.request.method === 'POST' && supabase && job) {
  const formData = await Astro.request.formData();
  const serviceTypeId = String(formData.get('service_type_id') ?? '').trim();
  const serviceType = (serviceTypes ?? []).find((item: any) => item.id === serviceTypeId);
  const estimatedBillableMinutes = minutesFromParts(formData.get('billable_hours'), formData.get('billable_minutes'));
  const status = String(formData.get('status') ?? 'new');
  const submittedClosedAt = String(formData.get('closed_at') ?? '').trim() || null;
  const payload = {
    job_reference: String(formData.get('job_reference') ?? '').trim(),
    client_id: String(formData.get('client_id') ?? '').trim(),
    title: String(formData.get('title') ?? '').trim(),
    category: String(formData.get('category') ?? 'support'),
    status,
    priority: String(formData.get('priority') ?? 'normal'),
    service_type_id: serviceTypeId || null,
    device_type: String(formData.get('device_type') ?? '').trim() || null,
    serial_number: String(formData.get('serial_number') ?? '').trim() || null,
    intake_details: String(formData.get('intake_details') ?? '').trim() || null,
    diagnosis: String(formData.get('diagnosis') ?? '').trim() || null,
    resolution_summary: String(formData.get('resolution_summary') ?? '').trim() || null,
    billable_minutes: estimatedBillableMinutes,
    hourly_rate_snapshot: serviceType?.hourly_rate ?? null,
    billing_increment_minutes_snapshot: serviceType?.billing_increment_minutes ?? null,
    calculated_billable_amount: Number(formData.get('calculated_billable_amount') ?? 0) || 0,
    invoice_number: String(formData.get('invoice_number') ?? '').trim() || null,
    invoice_status: String(formData.get('invoice_status') ?? 'not_invoiced'),
    opened_at: String(formData.get('opened_at') ?? '').trim() || null,
    closed_at: ['completed', 'cancelled'].includes(status) ? submittedClosedAt : null,
  };

  if (!payload.job_reference || !payload.client_id || !payload.title) {
    formError = 'Job reference, client, and title are required.';
  } else {
    const { error } = await supabase.from('jobs').update(payload).eq('id', id);
    if (error) {
      console.error('Failed to update job', error);
      formError = error.message;
    } else {
      return Astro.redirect(`/crm/jobs/${id}`);
    }
  }
}

function toLocalInput(value: string | null) {
  if (!value) return '';
  return value.slice(0, 16);
}

const actualBillableMinutes = (taskRows ?? []).reduce((sum, task) => sum + Number(task.billable_minutes ?? 0), 0);
const nonBillableMinutes = (taskRows ?? []).reduce((sum, task) => sum + Number(task.non_billable_minutes ?? 0), 0);
const estimateParts = splitMinutes(Number(job?.billable_minutes ?? 0));
---

<CrmLayout title="Edit job" description="Edit Bloomwood CRM job">
  <section class="mb-6 flex items-center justify-between gap-3">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Jobs</p>
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Edit job</h2>
    </div>
    <a href={`/crm/jobs/${id}`} class="rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-slate-100">Back</a>
  </section>

  {formError ? <section class="mb-6 rounded-2xl border border-rose-300 bg-rose-50 p-4 text-sm text-rose-950">{formError}</section> : null}

  {job ? (
    <form method="post" class="space-y-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <section class="grid gap-4 md:grid-cols-2">
        <label class="block text-sm font-medium text-slate-700">
          Job reference
          <input name="job_reference" required value={job.job_reference ?? ''} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Title
          <input name="title" required value={job.title ?? ''} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Client
          <select name="client_id" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
            {(clients ?? []).map((client: any) => <option value={client.id} selected={job.client_id === client.id}>{client.display_name}</option>)}
          </select>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Service type
          <select id="job-service-type" name="service_type_id" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
            <option value="">Select service</option>
            {(serviceTypes ?? []).map((serviceType: any) => <option value={serviceType.id} data-hourly-rate={serviceType.hourly_rate ?? ''} data-billing-increment={serviceType.billing_increment_minutes ?? ''} selected={job.service_type_id === serviceType.id}>{serviceType.name} ({serviceType.item_code})</option>)}
          </select>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Category
          <select name="category" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
            <option value="support" selected={job.category === 'support'}>Support</option>
            <option value="recovery" selected={job.category === 'recovery'}>Recovery</option>
            <option value="repair" selected={job.category === 'repair'}>Repair</option>
            <option value="flatpack" selected={job.category === 'flatpack'}>Flatpack</option>
            <option value="web" selected={job.category === 'web'}>Web</option>
            <option value="writing" selected={job.category === 'writing'}>Writing</option>
            <option value="other" selected={job.category === 'other'}>Other</option>
          </select>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Status
          <select id="job-status" name="status" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
            <option value="new" selected={job.status === 'new'}>New</option>
            <option value="in_progress" selected={job.status === 'in_progress'}>In progress</option>
            <option value="waiting_client" selected={job.status === 'waiting_client'}>Waiting client</option>
            <option value="waiting_parts" selected={job.status === 'waiting_parts'}>Waiting parts</option>
            <option value="ready" selected={job.status === 'ready'}>Ready</option>
            <option value="completed" selected={job.status === 'completed'}>Completed</option>
            <option value="cancelled" selected={job.status === 'cancelled'}>Cancelled</option>
          </select>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Priority
          <select name="priority" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
            <option value="low" selected={job.priority === 'low'}>Low</option>
            <option value="normal" selected={job.priority === 'normal'}>Normal</option>
            <option value="high" selected={job.priority === 'high'}>High</option>
            <option value="urgent" selected={job.priority === 'urgent'}>Urgent</option>
          </select>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Device type
          <input name="device_type" value={job.device_type ?? ''} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Serial number
          <input name="serial_number" value={job.serial_number ?? ''} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
      </section>

      <section class="grid gap-4 md:grid-cols-2">
        <label class="block text-sm font-medium text-slate-700 md:col-span-2">
          Intake details
          <textarea name="intake_details" rows="4" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">{job.intake_details ?? ''}</textarea>
        </label>
        <label class="block text-sm font-medium text-slate-700 md:col-span-2">
          Diagnosis
          <textarea name="diagnosis" rows="3" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">{job.diagnosis ?? ''}</textarea>
        </label>
        <label class="block text-sm font-medium text-slate-700 md:col-span-2">
          Resolution summary
          <textarea name="resolution_summary" rows="3" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">{job.resolution_summary ?? ''}</textarea>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Billable time estimate, hours
          <select id="job-billable-hours" name="billable_hours" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
            {Array.from({ length: 17 }, (_, i) => <option value={i} selected={estimateParts.hours === i}>{i}</option>)}
          </select>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Billable time estimate, minutes
          <select id="job-billable-minutes" name="billable_minutes" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
            {[0, 15, 30, 45].map((minute) => <option value={minute} selected={estimateParts.minutes === minute}>{minute}</option>)}
          </select>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Actual billable
          <input value={`${formatHours(actualBillableMinutes)} hrs`} readonly class="mt-1 w-full rounded-lg border border-slate-300 bg-slate-50 px-3 py-2 text-slate-600" />
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Non-billable time
          <input value={`${formatHours(nonBillableMinutes)} hrs`} readonly class="mt-1 w-full rounded-lg border border-slate-300 bg-slate-50 px-3 py-2 text-slate-600" />
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Calculated billable amount
          <input id="job-calculated-billable" type="number" min="0" step="0.01" name="calculated_billable_amount" value={job.calculated_billable_amount ?? 0} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Invoice number
          <input name="invoice_number" value={job.invoice_number ?? ''} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Invoice status
          <select name="invoice_status" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
            <option value="not_invoiced" selected={job.invoice_status === 'not_invoiced'}>Not invoiced</option>
            <option value="drafted" selected={job.invoice_status === 'drafted'}>Drafted</option>
            <option value="invoiced" selected={job.invoice_status === 'invoiced'}>Invoiced</option>
            <option value="paid" selected={job.invoice_status === 'paid'}>Paid</option>
            <option value="void" selected={job.invoice_status === 'void'}>Void</option>
          </select>
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Opened at
          <input type="datetime-local" name="opened_at" value={toLocalInput(job.opened_at)} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
        <label class="block text-sm font-medium text-slate-700">
          Closed at
          <input id="job-closed-at" type="datetime-local" name="closed_at" value={toLocalInput(job.closed_at)} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
      </section>

      <div class="flex justify-end gap-3">
        <a href={`/crm/jobs/${id}`} class="rounded-lg px-4 py-2 text-sm text-slate-700 hover:bg-slate-100">Cancel</a>
        <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Save job</button>
      </div>
    </form>
  ) : null}

  <script is:inline>
    const serviceTypeSelect = document.getElementById('job-service-type');
    const statusInput = document.getElementById('job-status');
    const closedAtInput = document.getElementById('job-closed-at');
    const billableHoursInput = document.getElementById('job-billable-hours');
    const billableMinutesInput = document.getElementById('job-billable-minutes');
    const calculatedBillableInput = document.getElementById('job-calculated-billable');

    function recalculateBillableAmount() {
      const selectedOption = serviceTypeSelect?.selectedOptions?.[0];
      if (!selectedOption || !billableHoursInput || !billableMinutesInput || !calculatedBillableInput) return;

      const hourlyRate = Number(selectedOption.getAttribute('data-hourly-rate') || 0);
      const increment = Number(selectedOption.getAttribute('data-billing-increment') || 0);
      const minutes = Math.max(0, (Number(billableHoursInput.value || 0) * 60) + Number(billableMinutesInput.value || 0));

      if (!hourlyRate) return;

      const roundedMinutes = increment > 0 ? Math.ceil(minutes / increment) * increment : minutes;
      const calculated = (roundedMinutes / 60) * hourlyRate;
      calculatedBillableInput.value = calculated.toFixed(2);
    }

    function syncClosedAtState() {
      if (!statusInput || !closedAtInput) return;
      if (!['completed', 'cancelled'].includes(statusInput.value)) {
        closedAtInput.value = '';
      }
    }

    serviceTypeSelect?.addEventListener('change', recalculateBillableAmount);
    billableHoursInput?.addEventListener('change', recalculateBillableAmount);
    billableMinutesInput?.addEventListener('change', recalculateBillableAmount);
    statusInput?.addEventListener('change', syncClosedAtState);
  </script>
</CrmLayout>
