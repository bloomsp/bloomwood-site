---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect('/crm/login?next=%2Fcrm%2Fjobs');
}

const supabase = (Astro.locals as any).supabase;
let jobs: Array<{
  id: string;
  job_reference: string;
  title: string;
  status: string;
  priority: string;
  invoice_number: string | null;
  billable_minutes: number;
  calculated_billable_amount: number;
  service_type: { name: string | null; item_code: string | null } | null;
  client: { display_name: string | null } | null;
  service_pack_usage_count: number;
  open_task_count: number;
}> = [];
let loadError: string | null = null;

function roundBillableMinutes(minutes: number, increment: number | null) {
  if (!increment || increment <= 0) return minutes;
  return Math.ceil(minutes / increment) * increment;
}

function getCalculatedAmount(minutes: number, hourlyRate: number | null, increment: number | null) {
  if (!hourlyRate || minutes <= 0) return 0;
  const roundedMinutes = roundBillableMinutes(minutes, increment);
  return (roundedMinutes / 60) * hourlyRate;
}

if (!supabase) {
  loadError = 'Supabase is not configured for this environment yet.';
} else {
  const { data, error } = await supabase
    .from('jobs')
    .select('id, client_id, job_reference, title, status, priority, invoice_number, billable_minutes, calculated_billable_amount, hourly_rate_snapshot, billing_increment_minutes_snapshot, client:clients(display_name), service_type:service_types(name, item_code)')
    .order('created_at', { ascending: false });

  if (error) {
    console.error('Failed to load CRM jobs', error);
    loadError = 'Could not load jobs yet. The CRM schema may not be applied in Supabase yet.';
  } else {
    const jobIds = (data ?? []).map((job) => job.id);
    const clientIds = [...new Set((data ?? []).map((job) => job.client_id).filter(Boolean))];
    const [tasksResult, servicePacksResult] = await Promise.all([
      jobIds.length
        ? supabase.from('tasks').select('id, job_id, status, billable_minutes, service_pack_id, completed_at').in('job_id', jobIds)
        : Promise.resolve({ data: [], error: null }),
      clientIds.length
        ? supabase.from('service_packs').select('id, client_id, minutes_purchased, hours_purchased').in('client_id', clientIds)
        : Promise.resolve({ data: [], error: null }),
    ]);

    if (tasksResult.error || servicePacksResult.error) {
      console.error('Failed to load CRM job summaries', tasksResult.error || servicePacksResult.error);
      loadError = 'Could not load job summaries yet. The latest CRM migration may still need to be applied.';
    } else {
      const purchasedMinutesByPack = new Map<string, number>((servicePacksResult.data ?? []).map((pack: any) => [pack.id, Number(pack.minutes_purchased ?? 0) || Math.round(Number(pack.hours_purchased ?? 0) * 60)]));
      const remainingMinutesByPack = new Map<string, number>(purchasedMinutesByPack);
      const orderedTasks = [...(tasksResult.data ?? [])].sort((a: any, b: any) => {
        const aTime = new Date(a.completed_at ?? 0).getTime();
        const bTime = new Date(b.completed_at ?? 0).getTime();
        return aTime - bTime;
      });

      const usageCounts = new Map<string, number>();
      const openTaskCounts = new Map<string, number>();
      const stillBillableMinutesByJob = new Map<string, number>();

      for (const task of orderedTasks) {
        const billableMinutes = Number((task as any).billable_minutes ?? 0);
        const packId = (task as any).service_pack_id;
        let packCoveredMinutes = 0;

        if (packId && billableMinutes > 0) {
          const remaining = Number(remainingMinutesByPack.get(packId) ?? 0);
          packCoveredMinutes = Math.min(billableMinutes, Math.max(0, remaining));
          remainingMinutesByPack.set(packId, Math.max(0, remaining - packCoveredMinutes));
        }

        if (packCoveredMinutes > 0) {
          usageCounts.set((task as any).job_id, (usageCounts.get((task as any).job_id) ?? 0) + 1);
        }

        stillBillableMinutesByJob.set((task as any).job_id, (stillBillableMinutesByJob.get((task as any).job_id) ?? 0) + Math.max(0, billableMinutes - packCoveredMinutes));

        if ((task as any).status !== 'done' && (task as any).status !== 'cancelled') {
          openTaskCounts.set((task as any).job_id, (openTaskCounts.get((task as any).job_id) ?? 0) + 1);
        }
      }

      jobs = (data ?? []).map((job: any) => ({
        ...job,
        calculated_billable_amount: getCalculatedAmount(
          Number(stillBillableMinutesByJob.get(job.id) ?? 0),
          Number(job.hourly_rate_snapshot ?? 0),
          Number(job.billing_increment_minutes_snapshot ?? 0) || null,
        ),
        billable_minutes: Number(job.billable_minutes ?? 0),
        service_pack_usage_count: usageCounts.get(job.id) ?? 0,
        open_task_count: openTaskCounts.get(job.id) ?? 0,
      }));
    }
  }
}
---

<CrmLayout title="Jobs" description="Bloomwood CRM jobs">
  <section class="mb-6 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Jobs</p>
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Active work</h2>
    </div>
    <a href="/crm/jobs/new" class="inline-flex items-center justify-center rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">
      Add job
    </a>
  </section>

  {loadError ? (
    <section class="mb-6 rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-950">
      {loadError}
    </section>
  ) : null}

  {jobs.length === 0 && !loadError ? (
    <section class="rounded-2xl border border-slate-200 bg-white p-5 text-sm text-slate-600 shadow-sm">
      No jobs yet. Once the CRM schema is live and records exist in Supabase, they’ll show here.
    </section>
  ) : null}

  <section class="space-y-4">
    {jobs.map((job) => (
      <a href={`/crm/jobs/${job.id}`} class="block rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-sky-300 hover:shadow">
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="text-sm font-medium text-slate-500">{job.job_reference}</div>
            <h3 class="mt-1 text-lg font-semibold text-slate-900">{job.title}</h3>
            {job.client?.display_name ? <p class="mt-1 text-sm text-slate-600">Client: {job.client.display_name}</p> : null}
            {job.service_type?.name ? (
              <p class="text-sm text-slate-600">
                Service: {job.service_type.name}
                {job.service_type.item_code ? ` (${job.service_type.item_code})` : ''}
              </p>
            ) : null}
            <p class="text-sm text-slate-600">Priority: {job.priority}</p>
          </div>
          <div class="text-right">
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium uppercase tracking-wide text-slate-700">{job.status}</span>
            <div class="mt-3 text-sm text-slate-600">Billable estimate: <span class="font-semibold text-slate-900">{(job.billable_minutes / 60).toFixed(2)}</span></div>
            <div class="text-sm text-slate-600">Still billable value: <span class="font-semibold text-slate-900">${job.calculated_billable_amount.toFixed(2)}</span></div>
            <div class="text-sm text-slate-600">Invoice number: <span class="font-semibold text-slate-900">{job.invoice_number ?? 'Not set'}</span></div>
            <div class="text-sm text-slate-600">Open tasks: <span class="font-semibold text-slate-900">{job.open_task_count}</span></div>
            <div class="text-sm text-slate-600">Tasks using packs: <span class="font-semibold text-slate-900">{job.service_pack_usage_count}</span></div>
          </div>
        </div>
      </a>
    ))}
  </section>
</CrmLayout>
