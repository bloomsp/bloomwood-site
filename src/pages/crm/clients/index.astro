---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect('/crm/login?next=%2Fcrm%2Fclients');
}

const supabase = (Astro.locals as any).supabase;
let clients: Array<{
  id: string;
  display_name: string;
  client_type: string;
  business_name: string | null;
  email: string | null;
  phone: string | null;
  status: string;
  total_billable_hours: number;
  total_billable_dollars: number;
  total_invoiced: number;
  active_service_packs: number;
  open_jobs: number;
  open_tasks: number;
}> = [];
let loadError: string | null = null;

if (!supabase) {
  loadError = 'Supabase is not configured for this environment yet.';
} else {
  const { data: clientRows, error: clientsError } = await supabase
    .from('clients')
    .select('id, display_name, client_type, business_name, email, phone, status')
    .order('display_name', { ascending: true });

  if (clientsError) {
    console.error('Failed to load CRM clients', clientsError);
    loadError = 'Could not load clients yet. The CRM schema may not be applied in Supabase yet.';
  } else {
    const clientIds = (clientRows ?? []).map((client) => client.id);

    const [jobsResult, tasksResult, servicePacksResult] = await Promise.all([
      clientIds.length
        ? supabase
            .from('jobs')
            .select('id, client_id, status, invoice_status')
            .in('client_id', clientIds)
        : Promise.resolve({ data: [], error: null }),
      clientIds.length
        ? supabase
            .from('tasks')
            .select('id, client_id, job_id, status, billable_minutes, service_pack_id, job:jobs(hourly_rate_snapshot, billing_increment_minutes_snapshot)')
            .in('client_id', clientIds)
        : Promise.resolve({ data: [], error: null }),
      clientIds.length
        ? supabase
            .from('service_packs')
            .select('client_id, status')
            .in('client_id', clientIds)
        : Promise.resolve({ data: [], error: null }),
    ]);

    if (jobsResult.error || tasksResult.error || servicePacksResult.error) {
      console.error('Failed to load CRM client summaries', jobsResult.error || tasksResult.error || servicePacksResult.error);
      loadError = 'Could not load client billing summary yet. The latest CRM migration may still need to be applied.';
    } else {
      function roundBillableMinutes(minutes: number, increment: number | null) {
        if (!increment || increment <= 0) return minutes;
        return Math.ceil(minutes / increment) * increment;
      }

      function getCalculatedAmount(minutes: number, hourlyRate: number | null, increment: number | null) {
        if (!hourlyRate || minutes <= 0) return 0;
        const roundedMinutes = roundBillableMinutes(minutes, increment);
        return (roundedMinutes / 60) * hourlyRate;
      }

      const packMinutesByTaskId = new Map<string, number>();
      const servicePackRows = (servicePacksResult.data ?? []).map((pack) => ({
        ...pack,
        total_minutes: Number((pack as any).minutes_purchased ?? 0) || 0,
      }));
      const remainingPackMinutes = new Map<string, number>();
      for (const pack of servicePackRows) {
        remainingPackMinutes.set(pack.id, pack.total_minutes);
      }

      const orderedTasks = [...(tasksResult.data ?? [])].sort((a: any, b: any) => {
        const aTime = new Date(a.completed_at ?? a.due_at ?? 0).getTime();
        const bTime = new Date(b.completed_at ?? b.due_at ?? 0).getTime();
        return aTime - bTime;
      });

      for (const task of orderedTasks) {
        const billableMinutes = Number((task as any).billable_minutes ?? 0);
        const servicePackId = (task as any).service_pack_id;
        if (!servicePackId || billableMinutes <= 0) {
          packMinutesByTaskId.set((task as any).id, 0);
          continue;
        }
        const remaining = Number(remainingPackMinutes.get(servicePackId) ?? 0);
        const packCovered = Math.min(billableMinutes, Math.max(0, remaining));
        remainingPackMinutes.set(servicePackId, Math.max(0, remaining - packCovered));
        packMinutesByTaskId.set((task as any).id, packCovered);
      }

      const jobsByClient = new Map<string, { totalBillableHours: number; totalBillableDollars: number; totalInvoiced: number; openJobs: number }>();
      const billableDollarsByJob = new Map<string, number>();
      for (const job of jobsResult.data ?? []) {
        const current = jobsByClient.get(job.client_id) ?? { totalBillableHours: 0, totalBillableDollars: 0, totalInvoiced: 0, openJobs: 0 };
        if (job.status && !['completed', 'cancelled'].includes(job.status)) {
          current.openJobs += 1;
        }
        jobsByClient.set(job.client_id, current);
      }

      const openTasksByClient = new Map<string, number>();
      for (const task of tasksResult.data ?? []) {
        const taskAny = task as any;
        const current = jobsByClient.get(taskAny.client_id) ?? { totalBillableHours: 0, totalBillableDollars: 0, totalInvoiced: 0, openJobs: 0 };
        const billableMinutes = Number(taskAny.billable_minutes ?? 0);
        const packCoveredMinutes = Number(packMinutesByTaskId.get(taskAny.id) ?? 0);
        const stillBillableMinutes = Math.max(0, billableMinutes - packCoveredMinutes);
        const taskDollars = getCalculatedAmount(
          stillBillableMinutes,
          Number(taskAny.job?.hourly_rate_snapshot ?? 0),
          Number(taskAny.job?.billing_increment_minutes_snapshot ?? 0) || null,
        );
        current.totalBillableHours += stillBillableMinutes / 60;
        current.totalBillableDollars += taskDollars;
        if (taskAny.job_id) {
          billableDollarsByJob.set(taskAny.job_id, (billableDollarsByJob.get(taskAny.job_id) ?? 0) + taskDollars);
        }
        if (taskAny.status !== 'done' && taskAny.status !== 'cancelled') {
          openTasksByClient.set(taskAny.client_id, (openTasksByClient.get(taskAny.client_id) ?? 0) + 1);
        }
        jobsByClient.set(taskAny.client_id, current);
      }

      for (const job of jobsResult.data ?? []) {
        const current = jobsByClient.get(job.client_id) ?? { totalBillableHours: 0, totalBillableDollars: 0, totalInvoiced: 0, openJobs: 0 };
        if (job.invoice_status && job.invoice_status !== 'not_invoiced' && job.invoice_status !== 'void') {
          current.totalInvoiced += billableDollarsByJob.get(job.id) ?? 0;
        }
        jobsByClient.set(job.client_id, current);
      }

      const packsByClient = new Map<string, number>();
      for (const pack of servicePacksResult.data ?? []) {
        if (pack.status === 'active') {
          packsByClient.set(pack.client_id, (packsByClient.get(pack.client_id) ?? 0) + 1);
        }
      }

      clients = (clientRows ?? []).map((client) => {
        const billing = jobsByClient.get(client.id) ?? { totalBillable: 0, totalInvoiced: 0 };
        return {
          ...client,
          total_billable_hours: billing.totalBillableHours ?? 0,
          total_billable_dollars: billing.totalBillableDollars ?? 0,
          total_invoiced: billing.totalInvoiced ?? 0,
          active_service_packs: packsByClient.get(client.id) ?? 0,
          open_jobs: billing.openJobs ?? 0,
          open_tasks: openTasksByClient.get(client.id) ?? 0,
        };
      });
    }
  }
}
---

<CrmLayout title="Clients" description="Bloomwood CRM clients">
  <section class="mb-6 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Clients</p>
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Client directory</h2>
    </div>
    <a href="/crm/clients/new" class="inline-flex items-center justify-center rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">
      Add client
    </a>
  </section>

  {loadError ? (
    <section class="mb-6 rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-950">
      {loadError}
    </section>
  ) : null}

  {clients.length === 0 && !loadError ? (
    <section class="rounded-2xl border border-slate-200 bg-white p-5 text-sm text-slate-600 shadow-sm">
      No clients yet. Once the CRM schema is live and records exist in Supabase, they’ll show here.
    </section>
  ) : null}

  <section class="space-y-4">
    {clients.map((client) => (
      <a href={`/crm/clients/${client.id}`} class="block rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-sky-300 hover:shadow">
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="mb-2 flex flex-wrap gap-2">
              <span class="rounded-full bg-sky-50 px-3 py-1 text-xs font-medium uppercase tracking-wide text-sky-700">{client.client_type}</span>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium uppercase tracking-wide text-slate-700">{client.status}</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">{client.display_name}</h3>
            {client.business_name ? <p class="mt-1 text-sm text-slate-600">{client.business_name}</p> : null}
            {client.email ? <p class="text-sm text-slate-600">{client.email}</p> : null}
            {client.phone ? <p class="text-sm text-slate-600">{client.phone}</p> : null}
          </div>
          <div class="min-w-[14rem] text-right text-sm text-slate-600">
            <div>Open jobs: <span class="font-semibold text-slate-900">{client.open_jobs}</span></div>
            <div>Open tasks: <span class="font-semibold text-slate-900">{client.open_tasks}</span></div>
            <div>Total billable: <span class="font-semibold text-slate-900">{client.total_billable_hours.toFixed(2)} hrs</span></div>
            <div>Total billable dollars: <span class="font-semibold text-slate-900">${client.total_billable_dollars.toFixed(2)}</span></div>
            <div>Total invoiced: <span class="font-semibold text-slate-900">${client.total_invoiced.toFixed(2)}</span></div>
            <div>Active packs: <span class="font-semibold text-slate-900">{client.active_service_packs}</span></div>
          </div>
        </div>
      </a>
    ))}
  </section>
</CrmLayout>
