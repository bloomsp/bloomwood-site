---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect('/crm/login?next=%2Fcrm%2Fclients');
}

const sampleClients = [
  {
    id: '1',
    name: 'Jane Citizen',
    email: 'jane@example.com',
    phone: '0400 000 000',
    status: 'active',
  },
  {
    id: '2',
    name: 'ACME Office Services',
    email: 'ops@acme.example',
    phone: '07 4000 0000',
    status: 'lead',
  },
];
---

<CrmLayout title="Clients" description="Bloomwood CRM clients">
  <section class="mb-6 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Clients</p>
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Client directory</h2>
    </div>
    <button class="inline-flex items-center justify-center rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">
      Add client
    </button>
  </section>

  <section class="space-y-4">
    {sampleClients.map((client) => (
      <a href={`/crm/clients/${client.id}`} class="block rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-sky-300 hover:shadow">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-lg font-semibold text-slate-900">{client.name}</h3>
            <p class="mt-1 text-sm text-slate-600">{client.email}</p>
            <p class="text-sm text-slate-600">{client.phone}</p>
          </div>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium uppercase tracking-wide text-slate-700">{client.status}</span>
        </div>
      </a>
    ))}
  </section>
</CrmLayout>
