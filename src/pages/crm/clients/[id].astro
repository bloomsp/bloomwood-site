---
import CrmLayout from '@/layouts/CrmLayout.astro';
import TaskCard from '@/components/crm/TaskCard.astro';
import { getCalculatedAmount, getTaskServicePackOptions } from '@/lib/crm-metrics.mjs';
import { summarizeClientDetail } from '@/lib/crm-page-contracts.mjs';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect(`/crm/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const { id } = Astro.params;
const supabase = (Astro.locals as any).supabase;

let client: any = null;
let jobs: any[] = [];
let notes: any[] = [];
let tasks: any[] = [];
let servicePacks: any[] = [];
let availableServicePacks: any[] = [];
let serviceTypes: any[] = [];
let invoices: any[] = [];
let invoiceLineItems: any[] = [];
let loadError: string | null = null;

function minutesFromParts(hours: FormDataEntryValue | null, minutes: FormDataEntryValue | null) {
  return ((Number(hours ?? 0) || 0) * 60) + (Number(minutes ?? 0) || 0);
}

async function syncClientServicePacks(clientId: string) {
  if (!supabase || !clientId) return;

  const [{ data: packs }, { data: packTasks }] = await Promise.all([
    supabase
      .from('service_packs')
      .select('id, minutes_purchased, hours_purchased')
      .eq('client_id', clientId),
    supabase
      .from('tasks')
      .select('service_pack_id, billable_minutes, completed_at, due_at')
      .eq('client_id', clientId)
      .not('service_pack_id', 'is', null)
      .gt('billable_minutes', 0)
      .order('completed_at', { ascending: true, nullsFirst: false })
      .order('due_at', { ascending: true, nullsFirst: false }),
  ]);

  const purchasedMinutesByPack = new Map<string, number>((packs ?? []).map((pack) => [pack.id, Number(pack.minutes_purchased ?? 0) || Math.round(Number(pack.hours_purchased ?? 0) * 60)]));
  const remainingMinutesByPack = new Map<string, number>(purchasedMinutesByPack);
  const usedMinutesByPack = new Map<string, number>();

  for (const task of packTasks ?? []) {
    const packId = task.service_pack_id as string | null;
    if (!packId) continue;
    const remaining = Number(remainingMinutesByPack.get(packId) ?? 0);
    const applied = Math.min(Number(task.billable_minutes ?? 0), Math.max(0, remaining));
    usedMinutesByPack.set(packId, (usedMinutesByPack.get(packId) ?? 0) + applied);
    remainingMinutesByPack.set(packId, Math.max(0, remaining - applied));
  }

  for (const pack of packs ?? []) {
    const totalPurchased = Number(purchasedMinutesByPack.get(pack.id) ?? 0);
    const actualUsed = Number(usedMinutesByPack.get(pack.id) ?? 0);
    const nextStatus = actualUsed >= totalPurchased ? 'used_up' : 'active';
    await supabase
      .from('service_packs')
      .update({ minutes_used: actualUsed, status: nextStatus })
      .eq('id', pack.id);
  }
}

if (Astro.request.method === 'POST' && supabase) {
  const formData = await Astro.request.formData();
  const action = String(formData.get('action') ?? '');

  if (action === 'add-note') {
    const payload = {
      client_id: id,
      note_type: String(formData.get('note_type') ?? 'internal'),
      body: String(formData.get('body') ?? '').trim(),
    };

    if (!payload.body) {
      loadError = 'Note body is required.';
    } else {
      const { error } = await supabase.from('job_notes').insert(payload);
      if (error) {
        console.error('Failed to create client note', error);
        loadError = error.message;
      } else {
        return Astro.redirect(`/crm/clients/${id}`);
      }
    }
  }

  if (action === 'add-task') {
    const billableMinutes = minutesFromParts(formData.get('billable_hours'), formData.get('billable_minutes'));
    const nonBillableMinutes = minutesFromParts(formData.get('non_billable_hours'), formData.get('non_billable_minutes'));
    const initialStatus = String(formData.get('status') ?? 'open');
    const payload = {
      client_id: id,
      service_type_id: String(formData.get('service_type_id') ?? '').trim() || null,
      service_pack_id: String(formData.get('service_pack_id') ?? '').trim() || null,
      title: String(formData.get('title') ?? '').trim(),
      details: String(formData.get('details') ?? '').trim() || null,
      status: initialStatus,
      due_at: String(formData.get('due_at') ?? '').trim() || null,
      billable_minutes: billableMinutes,
      non_billable_minutes: nonBillableMinutes,
      time_taken_minutes: billableMinutes + nonBillableMinutes,
      completed_at: initialStatus === 'done' ? new Date().toISOString() : null,
    };

    if (!payload.title) {
      loadError = 'Task title is required.';
    } else {
      const { error } = await supabase.from('tasks').insert(payload);
      if (error) {
        console.error('Failed to create client task', error);
        loadError = error.message;
      } else {
        await syncClientServicePacks(id);
        return Astro.redirect(`/crm/clients/${id}`);
      }
    }
  }

  if (action === 'complete-task') {
    const taskId = String(formData.get('task_id') ?? '').trim();
    const billableMinutes = minutesFromParts(formData.get('billable_hours'), formData.get('billable_minutes'));
    const nonBillableMinutes = minutesFromParts(formData.get('non_billable_hours'), formData.get('non_billable_minutes'));
    const servicePackId = String(formData.get('service_pack_id') ?? '').trim() || null;
    const totalMinutes = billableMinutes + nonBillableMinutes;
    if (!taskId) {
      loadError = 'Task id is required.';
    } else {
      const { error } = await supabase
        .from('tasks')
        .update({
          status: 'done',
          completed_at: new Date().toISOString(),
          billable_minutes: billableMinutes,
          non_billable_minutes: nonBillableMinutes,
          time_taken_minutes: totalMinutes,
          service_pack_id: servicePackId,
        })
        .eq('id', taskId)
        .eq('client_id', id);
      if (error) {
        console.error('Failed to complete client task', error);
        loadError = error.message;
      } else {
        await syncClientServicePacks(id);
        return Astro.redirect(`/crm/clients/${id}`);
      }
    }
  }

  if (action === 'create-invoice') {
    const invoiceNumber = String(formData.get('invoice_number') ?? '').trim() || null;
    const invoiceStatus = String(formData.get('invoice_status') ?? 'draft').trim() || 'draft';
    const notes = String(formData.get('invoice_notes') ?? '').trim() || null;
    const selectedJobIds = formData.getAll('invoice_job_ids').map((value) => String(value)).filter(Boolean);
    const selectedTaskIds = formData.getAll('invoice_task_ids').map((value) => String(value)).filter(Boolean);

    if (selectedJobIds.length === 0 && selectedTaskIds.length === 0) {
      loadError = 'Select at least one job or standalone task to include in the invoice.';
    } else {
      const { data: invoice, error: invoiceError } = await supabase
        .from('invoices')
        .insert({
          client_id: id,
          invoice_number: invoiceNumber,
          status: invoiceStatus,
          issued_at: invoiceStatus === 'issued' || invoiceStatus === 'paid' ? new Date().toISOString() : null,
          paid_at: invoiceStatus === 'paid' ? new Date().toISOString() : null,
          notes,
        })
        .select('id')
        .single();

      if (invoiceError || !invoice) {
        console.error('Failed to create invoice', invoiceError);
        loadError = invoiceError?.message ?? 'Could not create invoice.';
      } else {
        const { data: selectedJobs = [], error: selectedJobsError } = selectedJobIds.length > 0
          ? await supabase
              .from('jobs')
              .select('id, job_reference, title, calculated_billable_amount')
              .eq('client_id', id)
              .in('id', selectedJobIds)
          : { data: [], error: null };
        const { data: selectedTasks = [], error: selectedTasksError } = selectedTaskIds.length > 0
          ? await supabase
              .from('tasks')
              .select('id, title, billable_minutes, service_type:service_types(name, hourly_rate, billing_increment_minutes)')
              .eq('client_id', id)
              .is('job_id', null)
              .in('id', selectedTaskIds)
          : { data: [], error: null };

        if (selectedJobsError || selectedTasksError) {
          loadError = selectedJobsError?.message || selectedTasksError?.message || 'Could not load selected invoice items.';
        } else {
          const lineItems = [
            ...selectedJobs.map((job, index) => ({
              invoice_id: invoice.id,
              source_type: 'job',
              job_id: job.id,
              description: `${job.job_reference} · ${job.title}`,
              amount: Number(jobBillingBreakdown.get(job.id)?.stillBillableAmount ?? 0) || 0,
              sort_order: index,
            })),
            ...selectedTasks.map((task, index) => {
              const hourlyRate = Number(task?.service_type?.hourly_rate ?? 0);
              const increment = Number(task?.service_type?.billing_increment_minutes ?? 0) || null;
              const billableMinutes = Number(task.billable_minutes ?? 0) || 0;
              return {
                invoice_id: invoice.id,
                source_type: 'task',
                task_id: task.id,
                description: `${task.title}${task.service_type?.name ? ` · ${task.service_type.name}` : ''}`,
                quantity: billableMinutes / 60,
                unit_amount: hourlyRate || null,
                amount: getCalculatedAmount(billableMinutes, hourlyRate, increment),
                sort_order: selectedJobs.length + index,
              };
            }),
          ];

          const { error: itemsError } = await supabase.from('invoice_line_items').insert(lineItems);
          if (itemsError) {
            console.error('Failed to create invoice line items', itemsError);
            loadError = itemsError.message;
          } else {
            return Astro.redirect(`/crm/invoices/${invoice.id}`);
          }
        }
      }
    }
  }
}

if (!supabase) {
  loadError = 'Supabase is not configured for this environment yet.';
} else {
  const [clientResult, jobsResult, notesResult, tasksResult, packsResult, serviceTypesResult, invoicesResult, invoiceLineItemsResult] = await Promise.all([
    supabase.from('clients').select('*').eq('id', id).single(),
    supabase
      .from('jobs')
      .select('id, job_reference, title, status, priority, billable_minutes, calculated_billable_amount, hourly_rate_snapshot, billing_increment_minutes_snapshot, invoice_number, updated_at, service_type:service_types(name, item_code)')
      .eq('client_id', id)
      .order('updated_at', { ascending: false }),
    supabase
      .from('job_notes')
      .select('id, note_type, body, created_at')
      .eq('client_id', id)
      .order('created_at', { ascending: false })
      .limit(8),
    supabase
      .from('tasks')
      .select('id, title, details, status, due_at, completed_at, job_id, service_type_id, time_taken_minutes, billable_minutes, non_billable_minutes, service_pack_id, job:jobs(id, job_reference, title, invoice_number, hourly_rate_snapshot, billing_increment_minutes_snapshot), service_type:service_types(id, name, item_code, hourly_rate, billing_increment_minutes)')
      .eq('client_id', id)
      .order('completed_at', { ascending: true, nullsFirst: false }),
    supabase
      .from('service_packs')
      .select('id, hours_purchased, minutes_purchased, minutes_used, purchase_price, purchase_date, status, service_type:service_types(name, item_code)')
      .eq('client_id', id)
      .order('purchase_date', { ascending: false }),
    supabase
      .from('service_types')
      .select('id, name, item_code, hourly_rate, billing_increment_minutes, is_service_pack, active, sort_order')
      .eq('active', true)
      .eq('is_service_pack', false)
      .order('sort_order', { ascending: true }),
    supabase
      .from('invoices')
      .select('id, invoice_number, status, total_amount, created_at')
      .eq('client_id', id)
      .order('created_at', { ascending: false }),
    supabase
      .from('invoice_line_items')
      .select('id, invoice_id, source_type, job_id, task_id, amount, invoice:invoices(id, client_id, invoice_number, status)')
      .order('created_at', { ascending: false }),
  ]);

  if (clientResult.error || jobsResult.error || notesResult.error || tasksResult.error || packsResult.error || serviceTypesResult.error || invoicesResult.error || invoiceLineItemsResult.error) {
    console.error('Failed to load client detail', clientResult.error || jobsResult.error || notesResult.error || tasksResult.error || packsResult.error || serviceTypesResult.error || invoicesResult.error || invoiceLineItemsResult.error);
    loadError = 'Could not load this client yet. The latest CRM migration may still need to be applied.';
  } else {
    client = clientResult.data;
    jobs = jobsResult.data ?? [];
    notes = notesResult.data ?? [];
    tasks = tasksResult.data ?? [];
    const servicePackTaskCounts = new Map<string, number>();
    for (const task of tasks) {
      if (task.service_pack_id && Number(task.billable_minutes ?? 0) > 0) {
        servicePackTaskCounts.set(task.service_pack_id, (servicePackTaskCounts.get(task.service_pack_id) ?? 0) + 1);
      }
    }

    servicePacks = (packsResult.data ?? []).map((pack) => ({
      ...pack,
      task_count: servicePackTaskCounts.get(pack.id) ?? 0,
    }));
    serviceTypes = serviceTypesResult.data ?? [];
    invoices = invoicesResult.data ?? [];
    invoiceLineItems = (invoiceLineItemsResult.data ?? []).filter((item) => item.invoice?.client_id === id);
  }
}

const clientSummary = summarizeClientDetail({ jobs, tasks, packs: servicePacks, invoices, invoiceLineItems });
const {
  totalBillableMinutes,
  totalInvoiced,
  activeJobs,
  taskCount,
  totalPackMinutesRemaining,
  totalPackCoveredMinutes,
  totalToBeInvoicedMinutes,
  totalToBeInvoicedDollars,
  totalServicePackPurchased,
  totalRevenue,
  taskBillingBreakdown,
  jobBillingBreakdown,
  invoicedJobIds,
  invoicedTaskIds,
} = clientSummary;

const invoiceByJobId = new Map(invoiceLineItems.filter((item) => item.source_type === 'job' && item.job_id).map((item) => [item.job_id, item.invoice]));
const invoiceByTaskId = new Map(invoiceLineItems.filter((item) => item.source_type === 'task' && item.task_id).map((item) => [item.task_id, item.invoice]));
const eligibleInvoiceJobs = jobs.filter((job) => !invoicedJobIds.has(job.id));
const eligibleInvoiceTasks = tasks.filter((task) => !task.job_id && !invoicedTaskIds.has(task.id));

jobs = jobs.map((job) => ({ ...job, invoice: invoiceByJobId.get(job.id) ?? null }));
tasks = tasks.map((task) => ({ ...task, invoice: invoiceByTaskId.get(task.id) ?? (task.job_id ? invoiceByJobId.get(task.job_id) ?? null : null) }));

servicePacks = clientSummary.servicePacks.map((pack) => {
  const taskCount = servicePacks.find((item) => item.id === pack.id)?.task_count ?? 0;
  return { ...pack, task_count: taskCount };
});

availableServicePacks = servicePacks.filter((pack) => pack.status === 'active' && pack.minutes_remaining > 0);

function formatHours(minutes: number) {
  return (minutes / 60).toFixed(2);
}
---

<CrmLayout title="Client detail" description="Bloomwood CRM client detail">
  {loadError ? (
    <section class="rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-950">
      {loadError}
    </section>
  ) : !client ? (
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm text-slate-600">Client not found.</p>
    </section>
  ) : (
    <>
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <div class="mb-2 flex flex-wrap gap-2">
              <span class="rounded-full bg-sky-50 px-3 py-1 text-xs font-medium uppercase tracking-wide text-sky-700">{client.client_type}</span>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium uppercase tracking-wide text-slate-700">{client.status}</span>
            </div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Client</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">{client.display_name}</h2>
            {client.business_name ? <p class="mt-2 text-sm text-slate-600">{client.business_name}</p> : null}
            <div class="mt-3 space-y-1 text-sm text-slate-600">
              {client.email ? <p>{client.email}</p> : null}
              {client.phone ? <p>{client.phone}</p> : null}
              {client.address ? <p>{client.address}</p> : null}
              {client.preferred_contact_method ? <p>Preferred contact: {client.preferred_contact_method}</p> : null}
              {client.date_of_birth ? <p>Date of birth: {client.date_of_birth}</p> : null}
              {client.contact_name ? <p>Primary contact: {client.contact_name}{client.contact_role ? `, ${client.contact_role}` : ''}</p> : null}
            </div>
          </div>
          <div class="grid gap-3 md:w-[24rem]">
            <div class="flex flex-wrap justify-end gap-2">
              <a href={`/crm/clients/${id}/edit`} class="rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Edit client</a>
              <a href={`/crm/jobs/new?client_id=${id}`} class="rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Add job</a>
              <a href={`/crm/service-packs/new?client_id=${id}`} class="rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Add pack</a>
            </div>
            <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Active jobs</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{activeJobs}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Tasks</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{taskCount}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Total billable time</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{formatHours(totalBillableMinutes)} hrs</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">From service packs</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{formatHours(totalPackCoveredMinutes)} hrs</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Hours to be invoiced</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{formatHours(totalToBeInvoicedMinutes)} hrs</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Total to be invoiced</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">${totalToBeInvoicedDollars.toFixed(2)}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Total invoiced</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">${totalInvoiced.toFixed(2)}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Total service packs purchased</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">${totalServicePackPurchased.toFixed(2)}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Total revenue</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">${totalRevenue.toFixed(2)}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Service packs remaining</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{formatHours(totalPackMinutesRemaining)} hrs</div>
            </div>
            </div>
          </div>
        </div>
      </section>

      <section class="mt-6 grid gap-6 lg:grid-cols-[1.4fr_1fr]">
        <div class="space-y-6">
          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Jobs</h3>
            <div class="mt-4 space-y-3">
              {jobs.length === 0 ? <p class="text-sm text-slate-600">No jobs yet.</p> : null}
              {jobs.map((job) => (
                <a href={`/crm/jobs/${job.id}`} class="block rounded-xl border border-slate-200 p-4 hover:border-sky-300">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="text-sm font-medium text-slate-500">{job.job_reference}</div>
                      <div class="text-base font-semibold text-slate-900">{job.title}</div>
                      {job.service_type?.name ? <div class="text-sm text-slate-600">{job.service_type.name}{job.service_type.item_code ? ` (${job.service_type.item_code})` : ''}</div> : null}
                    </div>
                    <div class="text-right text-sm text-slate-600">
                      <div class="font-medium uppercase text-slate-700">{job.status}</div>
                      <div>Billable hours: {(Number(job.billable_minutes ?? 0) / 60).toFixed(2)}</div>
                      <div>Billable value: ${Number(job.calculated_billable_amount ?? 0).toFixed(2)}</div>
                      <div>Invoice: {job.invoice?.id ? <span class="font-semibold text-slate-900">{job.invoice.invoice_number ?? 'Draft invoice'}</span> : <span class="font-semibold text-slate-900">Not linked</span>}</div>
                      <div class="mt-2"><span class="rounded-lg border border-slate-300 px-2 py-1 text-xs text-slate-700">Edit</span></div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-lg font-semibold text-slate-900">Invoices</h3>
              <a href="/crm/invoices/" class="text-sm font-medium text-sky-700 hover:underline">View all</a>
            </div>
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="create-invoice" />
              <div class="grid gap-3 md:grid-cols-2">
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Invoice number</span>
                  <input name="invoice_number" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                </label>
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Status</span>
                  <select name="invoice_status" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    <option value="draft" selected>Draft</option>
                    <option value="issued">Issued</option>
                    <option value="paid">Paid</option>
                    <option value="void">Void</option>
                  </select>
                </label>
                <label class="text-sm text-slate-700 md:col-span-2">
                  <span class="mb-1 block">Jobs to include</span>
                  <div class="space-y-2 rounded-lg border border-slate-200 bg-white p-3">
                    {eligibleInvoiceJobs.length === 0 ? <p class="text-sm text-slate-500">No uninvoiced jobs available.</p> : eligibleInvoiceJobs.map((job) => (
                      <label class="flex items-center justify-between gap-3 text-sm text-slate-700">
                        <span><input type="checkbox" name="invoice_job_ids" value={job.id} class="mr-2" />{job.job_reference} · {job.title}</span>
                        <span class="font-medium text-slate-900">${Number(jobBillingBreakdown.get(job.id)?.stillBillableAmount ?? 0).toFixed(2)}</span>
                      </label>
                    ))}
                  </div>
                </label>
                <label class="text-sm text-slate-700 md:col-span-2">
                  <span class="mb-1 block">Standalone tasks to include</span>
                  <div class="space-y-2 rounded-lg border border-slate-200 bg-white p-3">
                    {eligibleInvoiceTasks.length === 0 ? <p class="text-sm text-slate-500">No uninvoiced standalone tasks available.</p> : eligibleInvoiceTasks.map((task) => (
                      <label class="flex items-center justify-between gap-3 text-sm text-slate-700">
                        <span><input type="checkbox" name="invoice_task_ids" value={task.id} class="mr-2" />{task.title}</span>
                        <span class="font-medium text-slate-900">{formatHours(Number(task.billable_minutes ?? 0))}h</span>
                      </label>
                    ))}
                  </div>
                </label>
                <label class="text-sm text-slate-700 md:col-span-2">
                  <span class="mb-1 block">Notes</span>
                  <textarea name="invoice_notes" rows="2" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
                </label>
              </div>
              <div class="mt-3 flex justify-end">
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Create invoice</button>
              </div>
            </form>
            <div class="mt-4 space-y-3">
              {invoices.length === 0 ? <p class="text-sm text-slate-600">No invoices yet.</p> : invoices.slice(0, 5).map((invoice) => (
                <a href={`/crm/invoices/${invoice.id}`} class="block rounded-xl border border-slate-200 p-4 hover:border-sky-300">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="text-sm font-semibold text-slate-900">{invoice.invoice_number ?? 'Draft invoice'}</div>
                      <div class="text-sm text-slate-600">Status: {invoice.status}</div>
                    </div>
                    <div class="text-right text-sm text-slate-600">
                      <div class="font-semibold text-slate-900">${Number(invoice.total_amount ?? 0).toFixed(2)}</div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Recent notes</h3>
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="add-note" />
              <div class="grid gap-3 md:grid-cols-[12rem_1fr_auto]">
                <select name="note_type" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="call">Call</option>
                  <option value="email">Email</option>
                  <option value="onsite">Onsite</option>
                  <option value="internal" selected>Internal</option>
                  <option value="recovery">Recovery</option>
                  <option value="delivery">Delivery</option>
                </select>
                <input name="body" placeholder="Add a quick note" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Add note</button>
              </div>
            </form>
            <div class="mt-4 space-y-3">
              {notes.length === 0 ? <p class="text-sm text-slate-600">No notes yet.</p> : null}
              {notes.map((note) => (
                <div class="rounded-xl border border-slate-200 p-4">
                  <div class="text-xs uppercase tracking-wide text-slate-500">{note.note_type} • {note.created_at}</div>
                  <p class="mt-2 text-sm leading-6 text-slate-700">{note.body}</p>
                </div>
              ))}
            </div>
          </section>
        </div>

        <div class="space-y-6">
          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Tasks</h3>
            <div class="mt-4 space-y-3">
              {tasks.length === 0 ? <p class="text-sm text-slate-600">No tasks yet.</p> : null}
              {tasks.map((task) => {
                const billingBreakdown = taskBillingBreakdown.get(task.id) ?? {
                  packCoveredMinutes: 0,
                  overflowBillableMinutes: Number(task.billable_minutes ?? 0),
                };
                const taskServicePackOptions = getTaskServicePackOptions({ availableServicePacks, servicePacks, task });
                return <TaskCard task={task} billingBreakdown={billingBreakdown} taskServicePackOptions={taskServicePackOptions} showJobLink={true} />;
              })}
            </div>
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="add-task" />
              <div class="grid gap-3 md:grid-cols-2">
                <input name="title" placeholder="Task title" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Due date</span>
                  <input type="datetime-local" name="due_at" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                </label>
                <input name="details" placeholder="Task details" class="rounded-lg border border-slate-300 px-3 py-2 text-sm md:col-span-2" />
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Billable hours</span>
                  <select name="billable_hours" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    {Array.from({ length: 9 }, (_, i) => <option value={i}>{i}</option>)}
                  </select>
                </label>
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Billable minutes</span>
                  <select name="billable_minutes" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    {[0, 15, 30, 45].map((minute) => <option value={minute}>{minute}</option>)}
                  </select>
                </label>
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Non-billable hours</span>
                  <select name="non_billable_hours" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    {Array.from({ length: 9 }, (_, i) => <option value={i}>{i}</option>)}
                  </select>
                </label>
                <label class="text-sm text-slate-700">
                  <span class="mb-1 block">Non-billable minutes</span>
                  <select name="non_billable_minutes" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    {[0, 15, 30, 45].map((minute) => <option value={minute}>{minute}</option>)}
                  </select>
                </label>
                <label class="text-sm text-slate-700 md:col-span-2">
                  <span class="mb-1 block">Service type</span>
                  <select name="service_type_id" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    <option value="">No service type</option>
                    {serviceTypes.map((serviceType) => (
                      <option value={serviceType.id}>{serviceType.name}{serviceType.item_code ? ` (${serviceType.item_code})` : ''}</option>
                    ))}
                  </select>
                  <p class="mt-1 text-xs text-slate-500">Use this for tasks not attached to a job so to-be-invoiced totals can use the correct rate.</p>
                </label>
                <label class="text-sm text-slate-700 md:col-span-2">
                  <span class="mb-1 block">Service pack</span>
                  <select name="service_pack_id" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    <option value="">No service pack</option>
                    {availableServicePacks.map((pack) => (
                      <option value={pack.id}>{pack.service_type?.name ?? 'Service pack'} ({formatHours(pack.minutes_remaining)} hrs remaining)</option>
                    ))}
                  </select>
                </label>
                <label class="text-sm text-slate-700 md:col-span-2">
                  <span class="mb-1 block">Task status</span>
                  <select name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    <option value="open" selected>Open</option>
                    <option value="done">Done</option>
                  </select>
                </label>
              </div>
              <div class="mt-3 flex justify-end">
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Add task</button>
              </div>
            </form>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Service packs</h3>
            <div class="mt-4 space-y-3">
              {servicePacks.length === 0 ? <p class="text-sm text-slate-600">No service packs yet.</p> : null}
              {servicePacks.map((pack) => (
                <a href={`/crm/service-packs/${pack.id}`} class="block rounded-xl border border-slate-200 p-4 hover:border-sky-300">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="text-sm font-semibold text-slate-900">{pack.service_type?.name ?? 'Service pack'}</div>
                      <div class="text-sm text-slate-600">Purchased: {pack.hours_purchased} hrs for ${Number(pack.purchase_price ?? 0).toFixed(2)}</div>
                      <div class="text-sm text-slate-600">Used: {formatHours(Number(pack.minutes_used ?? 0))} hrs, remaining: {formatHours(pack.minutes_remaining)} hrs</div>
                      <div class="text-sm text-slate-600">Tasks using this pack: {pack.task_count}</div>
                    </div>
                    <div class="text-right text-xs uppercase tracking-wide text-slate-500">
                      <div>{pack.status}</div>
                      {pack.purchase_date ? <div class="mt-1 normal-case tracking-normal">{pack.purchase_date}</div> : null}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        </div>
      </section>
    </>
  )}
</CrmLayout>
