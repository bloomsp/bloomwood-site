---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect(`/crm/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const { id } = Astro.params;
const supabase = (Astro.locals as any).supabase;

let client: any = null;
let jobs: any[] = [];
let notes: any[] = [];
let tasks: any[] = [];
let servicePacks: any[] = [];
let loadError: string | null = null;

if (Astro.request.method === 'POST' && supabase) {
  const formData = await Astro.request.formData();
  const action = String(formData.get('action') ?? '');

  if (action === 'add-note') {
    const payload = {
      client_id: id,
      note_type: String(formData.get('note_type') ?? 'internal'),
      body: String(formData.get('body') ?? '').trim(),
    };

    if (!payload.body) {
      loadError = 'Note body is required.';
    } else {
      const { error } = await supabase.from('job_notes').insert(payload);
      if (error) {
        console.error('Failed to create client note', error);
        loadError = error.message;
      } else {
        return Astro.redirect(`/crm/clients/${id}`);
      }
    }
  }

  if (action === 'add-task') {
    const payload = {
      client_id: id,
      title: String(formData.get('title') ?? '').trim(),
      details: String(formData.get('details') ?? '').trim() || null,
      status: String(formData.get('status') ?? 'open'),
      due_at: String(formData.get('due_at') ?? '').trim() || null,
    };

    if (!payload.title) {
      loadError = 'Task title is required.';
    } else {
      const { error } = await supabase.from('tasks').insert(payload);
      if (error) {
        console.error('Failed to create client task', error);
        loadError = error.message;
      } else {
        return Astro.redirect(`/crm/clients/${id}`);
      }
    }
  }
}

if (!supabase) {
  loadError = 'Supabase is not configured for this environment yet.';
} else {
  const [clientResult, jobsResult, notesResult, tasksResult, packsResult] = await Promise.all([
    supabase.from('clients').select('*').eq('id', id).single(),
    supabase
      .from('jobs')
      .select('id, job_reference, title, status, priority, calculated_billable_amount, invoice_number, updated_at, service_type:service_types(name, item_code)')
      .eq('client_id', id)
      .order('updated_at', { ascending: false }),
    supabase
      .from('job_notes')
      .select('id, note_type, body, created_at')
      .eq('client_id', id)
      .order('created_at', { ascending: false })
      .limit(8),
    supabase
      .from('tasks')
      .select('id, title, details, status, due_at, job_id')
      .eq('client_id', id)
      .order('due_at', { ascending: true }),
    supabase
      .from('service_packs')
      .select('id, hours_purchased, minutes_purchased, minutes_used, purchase_price, purchase_date, status, service_type:service_types(name, item_code)')
      .eq('client_id', id)
      .order('purchase_date', { ascending: false }),
  ]);

  if (clientResult.error || jobsResult.error || notesResult.error || tasksResult.error || packsResult.error) {
    console.error('Failed to load client detail', clientResult.error || jobsResult.error || notesResult.error || tasksResult.error || packsResult.error);
    loadError = 'Could not load this client yet. The latest CRM migration may still need to be applied.';
  } else {
    client = clientResult.data;
    jobs = jobsResult.data ?? [];
    notes = notesResult.data ?? [];
    tasks = tasksResult.data ?? [];
    servicePacks = (packsResult.data ?? []).map((pack) => ({
      ...pack,
      minutes_remaining: Math.max(0, Number(pack.minutes_purchased ?? 0) - Number(pack.minutes_used ?? 0)),
    }));
  }
}

const totalBillable = jobs.reduce((sum, job) => sum + Number(job.calculated_billable_amount ?? 0), 0);
const totalInvoiced = jobs.reduce((sum, job) => {
  return sum + (job.invoice_number ? Number(job.calculated_billable_amount ?? 0) : 0);
}, 0);
const activeJobs = jobs.filter((job) => !['completed', 'cancelled'].includes(job.status)).length;
const openTasks = tasks.filter((task) => task.status === 'open').length;
const activePacks = servicePacks.filter((pack) => pack.status === 'active');
const totalPackMinutesRemaining = activePacks.reduce((sum, pack) => sum + pack.minutes_remaining, 0);

function formatHours(minutes: number) {
  return (minutes / 60).toFixed(2);
}
---

<CrmLayout title="Client detail" description="Bloomwood CRM client detail">
  {loadError ? (
    <section class="rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-950">
      {loadError}
    </section>
  ) : !client ? (
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm text-slate-600">Client not found.</p>
    </section>
  ) : (
    <>
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <div class="mb-2 flex flex-wrap gap-2">
              <span class="rounded-full bg-sky-50 px-3 py-1 text-xs font-medium uppercase tracking-wide text-sky-700">{client.client_type}</span>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium uppercase tracking-wide text-slate-700">{client.status}</span>
            </div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Client</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">{client.display_name}</h2>
            {client.business_name ? <p class="mt-2 text-sm text-slate-600">{client.business_name}</p> : null}
            <div class="mt-3 space-y-1 text-sm text-slate-600">
              {client.email ? <p>{client.email}</p> : null}
              {client.phone ? <p>{client.phone}</p> : null}
              {client.address ? <p>{client.address}</p> : null}
              {client.preferred_contact_method ? <p>Preferred contact: {client.preferred_contact_method}</p> : null}
              {client.date_of_birth ? <p>Date of birth: {client.date_of_birth}</p> : null}
              {client.contact_name ? <p>Primary contact: {client.contact_name}{client.contact_role ? `, ${client.contact_role}` : ''}</p> : null}
            </div>
          </div>
          <div class="grid gap-3 md:w-[24rem]">
            <div class="flex flex-wrap justify-end gap-2">
              <a href={`/crm/clients/${id}/edit`} class="rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Edit client</a>
              <a href={`/crm/jobs/new?client_id=${id}`} class="rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Add job</a>
              <a href={`/crm/service-packs/new?client_id=${id}`} class="rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Add pack</a>
            </div>
            <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Active jobs</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{activeJobs}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Open tasks</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{openTasks}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Total billable</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">${totalBillable.toFixed(2)}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3">
              <div class="text-xs uppercase tracking-wide text-slate-500">Total invoiced</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">${totalInvoiced.toFixed(2)}</div>
            </div>
            <div class="rounded-xl bg-slate-50 p-3 col-span-2">
              <div class="text-xs uppercase tracking-wide text-slate-500">Service packs remaining</div>
              <div class="mt-1 text-xl font-semibold text-slate-900">{formatHours(totalPackMinutesRemaining)} hrs</div>
            </div>
            </div>
          </div>
        </div>
      </section>

      <section class="mt-6 grid gap-6 lg:grid-cols-[1.4fr_1fr]">
        <div class="space-y-6">
          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Jobs</h3>
            <div class="mt-4 space-y-3">
              {jobs.length === 0 ? <p class="text-sm text-slate-600">No jobs yet.</p> : null}
              {jobs.map((job) => (
                <a href={`/crm/jobs/${job.id}`} class="block rounded-xl border border-slate-200 p-4 hover:border-sky-300">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="text-sm font-medium text-slate-500">{job.job_reference}</div>
                      <div class="text-base font-semibold text-slate-900">{job.title}</div>
                      {job.service_type?.name ? <div class="text-sm text-slate-600">{job.service_type.name}{job.service_type.item_code ? ` (${job.service_type.item_code})` : ''}</div> : null}
                    </div>
                    <div class="text-right text-sm text-slate-600">
                      <div class="font-medium uppercase text-slate-700">{job.status}</div>
                      <div>${Number(job.calculated_billable_amount ?? 0).toFixed(2)}</div>
                      <div>{job.invoice_number ?? 'Not invoiced'}</div>
                      <div class="mt-2"><span class="rounded-lg border border-slate-300 px-2 py-1 text-xs text-slate-700">Edit</span></div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Recent notes</h3>
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="add-note" />
              <div class="grid gap-3 md:grid-cols-[12rem_1fr_auto]">
                <select name="note_type" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="call">Call</option>
                  <option value="email">Email</option>
                  <option value="onsite">Onsite</option>
                  <option value="internal" selected>Internal</option>
                  <option value="recovery">Recovery</option>
                  <option value="delivery">Delivery</option>
                </select>
                <input name="body" placeholder="Add a quick note" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Add note</button>
              </div>
            </form>
            <div class="mt-4 space-y-3">
              {notes.length === 0 ? <p class="text-sm text-slate-600">No notes yet.</p> : null}
              {notes.map((note) => (
                <div class="rounded-xl border border-slate-200 p-4">
                  <div class="text-xs uppercase tracking-wide text-slate-500">{note.note_type} • {note.created_at}</div>
                  <p class="mt-2 text-sm leading-6 text-slate-700">{note.body}</p>
                </div>
              ))}
            </div>
          </section>
        </div>

        <div class="space-y-6">
          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Open tasks</h3>
            <form method="post" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
              <input type="hidden" name="action" value="add-task" />
              <div class="grid gap-3 md:grid-cols-2">
                <input name="title" placeholder="Task title" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <input type="datetime-local" name="due_at" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <input name="details" placeholder="Task details" class="rounded-lg border border-slate-300 px-3 py-2 text-sm md:col-span-2" />
              </div>
              <div class="mt-3 flex justify-end">
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Add task</button>
              </div>
            </form>
            <div class="mt-4 space-y-3">
              {tasks.length === 0 ? <p class="text-sm text-slate-600">No tasks yet.</p> : null}
              {tasks.map((task) => (
                <div class="rounded-xl border border-slate-200 p-4">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="text-sm font-semibold text-slate-900">{task.title}</div>
                      {task.details ? <div class="mt-1 text-sm text-slate-600">{task.details}</div> : null}
                    </div>
                    <div class="text-right text-xs uppercase tracking-wide text-slate-500">
                      <div>{task.status}</div>
                      {task.due_at ? <div class="mt-1 normal-case tracking-normal">{task.due_at}</div> : null}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Service packs</h3>
            <div class="mt-4 space-y-3">
              {servicePacks.length === 0 ? <p class="text-sm text-slate-600">No service packs yet.</p> : null}
              {servicePacks.map((pack) => (
                <div class="rounded-xl border border-slate-200 p-4">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="text-sm font-semibold text-slate-900">{pack.service_type?.name ?? 'Service pack'}</div>
                      <div class="text-sm text-slate-600">Purchased: {pack.hours_purchased} hrs for ${Number(pack.purchase_price ?? 0).toFixed(2)}</div>
                      <div class="text-sm text-slate-600">Used: {formatHours(Number(pack.minutes_used ?? 0))} hrs, remaining: {formatHours(pack.minutes_remaining)} hrs</div>
                    </div>
                    <div class="text-right text-xs uppercase tracking-wide text-slate-500">
                      <div>{pack.status}</div>
                      <div class="mt-1 normal-case tracking-normal">{pack.purchase_date}</div>
                      <div class="mt-2 normal-case"><a href={`/crm/service-packs/${pack.id}/edit`} class="text-sm font-medium text-sky-700 hover:underline">Edit</a></div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        </div>
      </section>
    </>
  )}
</CrmLayout>
