---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect('/crm/login?next=%2Fcrm%2Fclients%2Fnew');
}

const supabase = (Astro.locals as any).supabase;
let formError: string | null = null;

const values = {
  client_type: String(Astro.url.searchParams.get('client_type') ?? 'person'),
  display_name: String(Astro.url.searchParams.get('display_name') ?? ''),
  first_name: String(Astro.url.searchParams.get('first_name') ?? ''),
  last_name: String(Astro.url.searchParams.get('last_name') ?? ''),
  business_name: String(Astro.url.searchParams.get('business_name') ?? ''),
  contact_name: String(Astro.url.searchParams.get('contact_name') ?? ''),
  contact_role: String(Astro.url.searchParams.get('contact_role') ?? ''),
  date_of_birth: String(Astro.url.searchParams.get('date_of_birth') ?? ''),
  email: String(Astro.url.searchParams.get('email') ?? ''),
  phone: String(Astro.url.searchParams.get('phone') ?? ''),
  address: String(Astro.url.searchParams.get('address') ?? ''),
  preferred_contact_method: String(Astro.url.searchParams.get('preferred_contact_method') ?? 'email'),
  status: String(Astro.url.searchParams.get('status') ?? 'active'),
  tags: String(Astro.url.searchParams.get('tags') ?? ''),
};

if (Astro.request.method === 'POST') {
  if (!supabase) {
    formError = 'Supabase is not configured for this environment yet.';
  } else {
    const formData = await Astro.request.formData();
    const clientType = String(formData.get('client_type') ?? 'person');
    const payload = {
      client_type: clientType,
      display_name: String(formData.get('display_name') ?? '').trim(),
      first_name: String(formData.get('first_name') ?? '').trim() || null,
      last_name: String(formData.get('last_name') ?? '').trim() || null,
      business_name: String(formData.get('business_name') ?? '').trim() || null,
      contact_name: String(formData.get('contact_name') ?? '').trim() || null,
      contact_role: String(formData.get('contact_role') ?? '').trim() || null,
      date_of_birth: String(formData.get('date_of_birth') ?? '').trim() || null,
      email: String(formData.get('email') ?? '').trim() || null,
      phone: String(formData.get('phone') ?? '').trim() || null,
      address: String(formData.get('address') ?? '').trim() || null,
      preferred_contact_method: String(formData.get('preferred_contact_method') ?? 'email'),
      status: String(formData.get('status') ?? 'active'),
      tags: String(formData.get('tags') ?? '')
        .split(',')
        .map((tag) => tag.trim())
        .filter(Boolean),
    };

    if (!payload.display_name) {
      formError = 'Display name is required.';
    } else if (clientType === 'person' && !payload.first_name && !payload.last_name) {
      formError = 'Add at least a first name or last name for a person.';
    } else if (clientType === 'company' && !payload.business_name) {
      formError = 'Business name is required for a company client.';
    } else {
      const { data, error } = await supabase.from('clients').insert(payload).select('id').single();
      if (error || !data) {
        console.error('Failed to create client', error);
        formError = error?.message ?? 'Could not save the client.';
      } else {
        return Astro.redirect(`/crm/clients/${data.id}`);
      }
    }
  }
}
---

<CrmLayout title="New client" description="Create Bloomwood CRM client">
  <section class="mb-6 flex items-center justify-between gap-3">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Clients</p>
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Add client</h2>
    </div>
    <a href="/crm/clients" class="rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-slate-100">Back</a>
  </section>

  {formError ? <section class="mb-6 rounded-2xl border border-rose-300 bg-rose-50 p-4 text-sm text-rose-950">{formError}</section> : null}

  <form method="post" class="space-y-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <section class="grid gap-4 md:grid-cols-2">
      <label class="block text-sm font-medium text-slate-700">
        Client type
        <select name="client_type" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
          <option value="person" selected={values.client_type === 'person'}>Person</option>
          <option value="company" selected={values.client_type === 'company'}>Company</option>
        </select>
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Display name
        <input name="display_name" required value={values.display_name} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        First name
        <input name="first_name" value={values.first_name} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Last name
        <input name="last_name" value={values.last_name} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700 md:col-span-2">
        Business name
        <input name="business_name" value={values.business_name} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Primary contact name
        <input name="contact_name" value={values.contact_name} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Contact role
        <input name="contact_role" value={values.contact_role} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Date of birth
        <input type="date" name="date_of_birth" value={values.date_of_birth} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Status
        <select name="status" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
          <option value="active" selected={values.status === 'active'}>Active</option>
          <option value="lead" selected={values.status === 'lead'}>Lead</option>
          <option value="inactive" selected={values.status === 'inactive'}>Inactive</option>
          <option value="archived" selected={values.status === 'archived'}>Archived</option>
        </select>
      </label>
    </section>

    <section class="grid gap-4 md:grid-cols-2">
      <label class="block text-sm font-medium text-slate-700">
        Email
        <input type="email" name="email" value={values.email} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Phone
        <input name="phone" value={values.phone} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="block text-sm font-medium text-slate-700 md:col-span-2">
        Address
        <textarea name="address" rows="3" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">{values.address}</textarea>
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Preferred contact method
        <select name="preferred_contact_method" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
          <option value="email" selected={values.preferred_contact_method === 'email'}>Email</option>
          <option value="phone" selected={values.preferred_contact_method === 'phone'}>Phone</option>
          <option value="sms" selected={values.preferred_contact_method === 'sms'}>SMS</option>
          <option value="other" selected={values.preferred_contact_method === 'other'}>Other</option>
        </select>
      </label>
      <label class="block text-sm font-medium text-slate-700">
        Tags
        <input name="tags" value={values.tags} placeholder="recovery, vip, service-pack" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
    </section>

    <div class="flex justify-end gap-3">
      <a href="/crm/clients" class="rounded-lg px-4 py-2 text-sm text-slate-700 hover:bg-slate-100">Cancel</a>
      <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Create client</button>
    </div>
  </form>
</CrmLayout>

