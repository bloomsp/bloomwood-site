---
import CrmLayout from '@/layouts/CrmLayout.astro';
import { formatCrmDateTime } from '@/lib/crm-page-contracts.mjs';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect(`/crm/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const { id } = Astro.params;
const supabase = (Astro.locals as any).supabase;
let loadError: string | null = null;
let invoice: any = null;
let lineItems: any[] = [];
let isPaidInvoice = false;

if (!supabase) {
  loadError = 'Supabase is not configured for this environment yet.';
} else {
  if (Astro.request.method === 'POST') {
    const { data: existingInvoice, error: existingInvoiceError } = await supabase
      .from('invoices')
      .select('id, status')
      .eq('id', id)
      .single();

    if (existingInvoiceError || !existingInvoice) {
      console.error('Failed to load invoice before mutation', existingInvoiceError);
      loadError = existingInvoiceError?.message ?? 'Could not load invoice.';
    } else {
      const formData = await Astro.request.formData();
      const action = String(formData.get('action') ?? '').trim();
      const isLockedInvoice = existingInvoice.status === 'paid';
      const isMutationAction = ['update-invoice', 'mark-paid', 'void-invoice', 'add-manual-line-item', 'update-manual-line-item', 'delete-manual-line-item'].includes(action);

      if (isLockedInvoice && isMutationAction) {
        loadError = 'Paid invoices are locked and can no longer be edited.';
      } else if (action === 'update-invoice') {
        const invoiceNumber = String(formData.get('invoice_number') ?? '').trim() || null;
        const status = String(formData.get('status') ?? 'draft').trim() || 'draft';
        const notes = String(formData.get('notes') ?? '').trim() || null;
        const externalProvider = String(formData.get('external_provider') ?? '').trim() || null;
        const externalInvoiceId = String(formData.get('external_invoice_id') ?? '').trim() || null;
        const payload: Record<string, any> = {
          invoice_number: invoiceNumber,
          status,
          notes,
          external_provider: externalProvider,
          external_invoice_id: externalInvoiceId,
        };

        if (status === 'issued' && !String(formData.get('issued_at') ?? '').trim()) {
          payload.issued_at = new Date().toISOString();
        }
        if (status === 'paid') {
          payload.issued_at = String(formData.get('issued_at') ?? '').trim() || new Date().toISOString();
          payload.paid_at = String(formData.get('paid_at') ?? '').trim() || new Date().toISOString();
        }
        if (status === 'draft') {
          payload.issued_at = null;
          payload.paid_at = null;
        }
        if (status === 'void') {
          payload.paid_at = null;
        }

        const { error } = await supabase.from('invoices').update(payload).eq('id', id);
        if (error) {
          console.error('Failed to update invoice', error);
          loadError = error.message;
        } else {
          return Astro.redirect(`/crm/invoices/${id}`);
        }
      } else if (action === 'mark-paid') {
        const now = new Date().toISOString();
        const { error } = await supabase
          .from('invoices')
          .update({ status: 'paid', issued_at: now, paid_at: now })
          .eq('id', id);
        if (error) {
          console.error('Failed to mark invoice paid', error);
          loadError = error.message;
        } else {
          return Astro.redirect(`/crm/invoices/${id}`);
        }
      } else if (action === 'void-invoice') {
        const { error } = await supabase
          .from('invoices')
          .update({ status: 'void', paid_at: null })
          .eq('id', id);
        if (error) {
          console.error('Failed to void invoice', error);
          loadError = error.message;
        } else {
          return Astro.redirect(`/crm/invoices/${id}`);
        }
      } else if (action === 'add-manual-line-item' || action === 'update-manual-line-item') {
        const lineItemId = String(formData.get('line_item_id') ?? '').trim() || null;
        const description = String(formData.get('description') ?? '').trim();
        const quantityValue = String(formData.get('quantity') ?? '').trim();
        const unitAmountValue = String(formData.get('unit_amount') ?? '').trim();
        const amountValue = String(formData.get('amount') ?? '').trim();
        const quantity = quantityValue ? Number(quantityValue) : null;
        const unitAmount = unitAmountValue ? Number(unitAmountValue) : null;
        const amount = amountValue ? Number(amountValue) : ((quantity ?? 1) * (unitAmount ?? 0));

        if (!description) {
          loadError = 'Manual line item description is required.';
        } else if ((quantityValue && Number.isNaN(quantity)) || (unitAmountValue && Number.isNaN(unitAmount)) || Number.isNaN(amount)) {
          loadError = 'Manual line item values must be valid numbers.';
        } else if (action === 'update-manual-line-item' && !lineItemId) {
          loadError = 'Manual line item id is required.';
        } else if (action === 'add-manual-line-item') {
          const { data: lastLineItem } = await supabase
            .from('invoice_line_items')
            .select('sort_order')
            .eq('invoice_id', id)
            .order('sort_order', { ascending: false })
            .limit(1)
            .maybeSingle();
          const nextSortOrder = Number(lastLineItem?.sort_order ?? -1) + 1;

          const { error } = await supabase.from('invoice_line_items').insert({
            invoice_id: id,
            source_type: 'manual',
            description,
            quantity,
            unit_amount: unitAmount,
            amount,
            sort_order: nextSortOrder,
          });
          if (error) {
            console.error('Failed to add manual invoice line item', error);
            loadError = error.message;
          } else {
            return Astro.redirect(`/crm/invoices/${id}`);
          }
        } else {
          const { error } = await supabase
            .from('invoice_line_items')
            .update({ description, quantity, unit_amount: unitAmount, amount })
            .eq('id', lineItemId)
            .eq('invoice_id', id)
            .eq('source_type', 'manual');
          if (error) {
            console.error('Failed to update manual invoice line item', error);
            loadError = error.message;
          } else {
            return Astro.redirect(`/crm/invoices/${id}`);
          }
        }
      } else if (action === 'delete-manual-line-item') {
        const lineItemId = String(formData.get('line_item_id') ?? '').trim();
        if (!lineItemId) {
          loadError = 'Manual line item id is required.';
        } else {
          const { error } = await supabase
            .from('invoice_line_items')
            .delete()
            .eq('id', lineItemId)
            .eq('invoice_id', id)
            .eq('source_type', 'manual');
          if (error) {
            console.error('Failed to delete manual invoice line item', error);
            loadError = error.message;
          } else {
            return Astro.redirect(`/crm/invoices/${id}`);
          }
        }
      }
    }
  }

  const [invoiceResult, itemsResult] = await Promise.all([
    supabase.from('invoices').select('*, client:clients(id, display_name)').eq('id', id).single(),
    supabase.from('invoice_line_items').select('id, source_type, description, quantity, unit_amount, amount, job:jobs(id, job_reference), task:tasks(id, title), service_pack:service_packs(id)').eq('invoice_id', id).order('sort_order', { ascending: true }),
  ]);

  if (invoiceResult.error || itemsResult.error) {
    console.error('Failed to load invoice detail', invoiceResult.error || itemsResult.error);
    loadError = invoiceResult.error?.message || itemsResult.error?.message || 'Could not load invoice.';
  } else {
    invoice = invoiceResult.data;
    lineItems = itemsResult.data ?? [];
    isPaidInvoice = invoice?.status === 'paid';
  }
}

function toLocalInput(value: string | null) {
  if (!value) return '';
  return value.slice(0, 16);
}
---

<CrmLayout title="Invoice detail" description="Bloomwood CRM invoice detail">
  {loadError ? <section class="mb-6 rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-950">{loadError}</section> : null}
  {!loadError && !invoice ? <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm text-slate-600">Invoice not found.</p></section> : null}
  {invoice ? (
    <>
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Invoice</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">{invoice.invoice_number ?? 'Draft invoice'}</h2>
            <div class="mt-2 text-sm text-slate-600">Client: {invoice.client?.display_name ?? 'Unknown client'}</div>
            <div class="text-sm text-slate-600">Status: {invoice.status}</div>
            {invoice.external_provider ? <div class="text-sm text-slate-600">Provider: {invoice.external_provider}</div> : null}
            {invoice.external_invoice_id ? <div class="text-sm text-slate-600">External ID: {invoice.external_invoice_id}</div> : null}
            {invoice.issued_at ? <div class="text-sm text-slate-600">Issued: {formatCrmDateTime(invoice.issued_at)}</div> : null}
            {invoice.paid_at ? <div class="text-sm text-slate-600">Paid: {formatCrmDateTime(invoice.paid_at)}</div> : null}
          </div>
          <div class="text-right">
            <div class="text-xs uppercase tracking-wide text-slate-500">Total</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">${Number(invoice.total_amount ?? 0).toFixed(2)}</div>
          </div>
        </div>

        {isPaidInvoice ? <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900">This invoice is paid and locked. Editing and line-item changes are disabled.</div> : null}

        <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto]">
          <form method="post" class="grid gap-4 rounded-xl border border-slate-200 bg-slate-50 p-4 md:grid-cols-2">
            <input type="hidden" name="action" value="update-invoice" />
            <label class="text-sm text-slate-700">
              <span class="mb-1 block">Invoice number</span>
              <input name="invoice_number" value={invoice.invoice_number ?? ''} disabled={isPaidInvoice} class="w-full rounded-lg border border-slate-300 px-3 py-2 disabled:bg-slate-100 disabled:text-slate-500" />
            </label>
            <label class="text-sm text-slate-700">
              <span class="mb-1 block">Status</span>
              <select name="status" disabled={isPaidInvoice} class="w-full rounded-lg border border-slate-300 px-3 py-2 disabled:bg-slate-100 disabled:text-slate-500">
                <option value="draft" selected={invoice.status === 'draft'}>Draft</option>
                <option value="issued" selected={invoice.status === 'issued'}>Issued</option>
                <option value="paid" selected={invoice.status === 'paid'}>Paid</option>
                <option value="void" selected={invoice.status === 'void'}>Void</option>
              </select>
            </label>
            <label class="text-sm text-slate-700">
              <span class="mb-1 block">Provider</span>
              <input name="external_provider" value={invoice.external_provider ?? 'Xero'} disabled={isPaidInvoice} class="w-full rounded-lg border border-slate-300 px-3 py-2 disabled:bg-slate-100 disabled:text-slate-500" />
            </label>
            <label class="text-sm text-slate-700">
              <span class="mb-1 block">External invoice ID</span>
              <input name="external_invoice_id" value={invoice.external_invoice_id ?? ''} disabled={isPaidInvoice} placeholder="Xero invoice ID or reference" class="w-full rounded-lg border border-slate-300 px-3 py-2 disabled:bg-slate-100 disabled:text-slate-500" />
            </label>
            <label class="text-sm text-slate-700">
              <span class="mb-1 block">Issued at</span>
              <input type="datetime-local" name="issued_at" value={toLocalInput(invoice.issued_at)} disabled={isPaidInvoice} class="w-full rounded-lg border border-slate-300 px-3 py-2 disabled:bg-slate-100 disabled:text-slate-500" />
            </label>
            <label class="text-sm text-slate-700">
              <span class="mb-1 block">Paid at</span>
              <input type="datetime-local" name="paid_at" value={toLocalInput(invoice.paid_at)} disabled={isPaidInvoice} class="w-full rounded-lg border border-slate-300 px-3 py-2 disabled:bg-slate-100 disabled:text-slate-500" />
            </label>
            <label class="text-sm text-slate-700 md:col-span-2">
              <span class="mb-1 block">Notes</span>
              <textarea name="notes" rows="3" disabled={isPaidInvoice} class="w-full rounded-lg border border-slate-300 px-3 py-2 disabled:bg-slate-100 disabled:text-slate-500">{invoice.notes ?? ''}</textarea>
            </label>
            <div class="md:col-span-2 flex justify-end">
              <button disabled={isPaidInvoice} class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700 disabled:cursor-not-allowed disabled:bg-slate-300">Save invoice</button>
            </div>
          </form>

          <div class="flex flex-col gap-3">
            <form method="post">
              <input type="hidden" name="action" value="mark-paid" />
              <button disabled={isPaidInvoice} class="w-full rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700 disabled:cursor-not-allowed disabled:bg-slate-300">Mark paid</button>
            </form>
            <form method="post">
              <input type="hidden" name="action" value="void-invoice" />
              <button disabled={isPaidInvoice} class="w-full rounded-lg bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700 disabled:cursor-not-allowed disabled:bg-slate-300">Void invoice</button>
            </form>
          </div>
        </div>
      </section>

      <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-lg font-semibold text-slate-900">Line items</h3>
          <div class="text-sm text-slate-500">{lineItems.length} item{lineItems.length === 1 ? '' : 's'}</div>
        </div>
        {!isPaidInvoice ? (
          <form method="post" class="mt-4 grid gap-4 rounded-xl border border-slate-200 bg-slate-50 p-4 md:grid-cols-4">
            <input type="hidden" name="action" value="add-manual-line-item" />
            <label class="text-sm text-slate-700 md:col-span-2">
              <span class="mb-1 block">Description</span>
              <input name="description" class="w-full rounded-lg border border-slate-300 px-3 py-2" placeholder="Additional charge or adjustment" />
            </label>
            <label class="text-sm text-slate-700">
              <span class="mb-1 block">Qty</span>
              <input type="number" min="0" step="0.01" name="quantity" class="w-full rounded-lg border border-slate-300 px-3 py-2" placeholder="1" />
            </label>
            <label class="text-sm text-slate-700">
              <span class="mb-1 block">Unit amount</span>
              <input type="number" min="0" step="0.01" name="unit_amount" class="w-full rounded-lg border border-slate-300 px-3 py-2" placeholder="0.00" />
            </label>
            <label class="text-sm text-slate-700 md:col-span-1">
              <span class="mb-1 block">Amount override</span>
              <input type="number" min="0" step="0.01" name="amount" class="w-full rounded-lg border border-slate-300 px-3 py-2" placeholder="Auto-calc if blank" />
            </label>
            <div class="md:col-span-3 flex items-end justify-end">
              <button class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700">Add manual line item</button>
            </div>
          </form>
        ) : null}
        <div class="mt-4 space-y-3">
          {lineItems.length === 0 ? <p class="text-sm text-slate-600">No line items yet.</p> : null}
          {lineItems.map((item) => (
            <div class="rounded-xl border border-slate-200 p-4">
              {item.source_type === 'manual' && !isPaidInvoice ? (
                <>
                  <form method="post" class="space-y-4">
                    <input type="hidden" name="action" value="update-manual-line-item" />
                    <input type="hidden" name="line_item_id" value={item.id} />
                    <div class="grid gap-4 md:grid-cols-4">
                      <label class="text-sm text-slate-700 md:col-span-2">
                        <span class="mb-1 block">Description</span>
                        <input name="description" value={item.description ?? ''} class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                      </label>
                      <label class="text-sm text-slate-700">
                        <span class="mb-1 block">Qty</span>
                        <input type="number" min="0" step="0.01" name="quantity" value={item.quantity ?? ''} class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                      </label>
                      <label class="text-sm text-slate-700">
                        <span class="mb-1 block">Unit amount</span>
                        <input type="number" min="0" step="0.01" name="unit_amount" value={item.unit_amount ?? ''} class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                      </label>
                      <label class="text-sm text-slate-700 md:col-span-1">
                        <span class="mb-1 block">Amount</span>
                        <input type="number" min="0" step="0.01" name="amount" value={item.amount ?? ''} class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                      </label>
                      <div class="md:col-span-3 flex items-end justify-end gap-3">
                        <div class="text-right text-sm text-slate-600">
                          <div class="font-semibold text-slate-900">${Number(item.amount ?? 0).toFixed(2)}</div>
                        </div>
                        <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Save</button>
                      </div>
                    </div>
                  </form>
                  <form method="post" class="mt-3 flex justify-end">
                    <input type="hidden" name="action" value="delete-manual-line-item" />
                    <input type="hidden" name="line_item_id" value={item.id} />
                    <button class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700">Delete</button>
                  </form>
                </>
              ) : (
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <div class="text-sm font-semibold text-slate-900">{item.description}</div>
                    <div class="text-sm text-slate-600">Type: {item.source_type}</div>
                    {item.job?.id ? <div class="text-sm text-slate-600">Job: <a class="font-medium text-sky-700 hover:underline" href={`/crm/jobs/${item.job.id}`}>{item.job.job_reference}</a></div> : null}
                    {item.task?.id ? <div class="text-sm text-slate-600">Task: {item.task.title}</div> : null}
                  </div>
                  <div class="text-right text-sm text-slate-600">
                    {item.quantity ? <div>Qty: {Number(item.quantity).toFixed(2)}</div> : null}
                    {item.unit_amount ? <div>Unit: ${Number(item.unit_amount).toFixed(2)}</div> : null}
                    <div class="font-semibold text-slate-900">${Number(item.amount ?? 0).toFixed(2)}</div>
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    </>
  ) : null}
</CrmLayout>
