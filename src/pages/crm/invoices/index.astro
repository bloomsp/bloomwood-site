---
import CrmLayout from '@/layouts/CrmLayout.astro';
import { formatCrmDateTime } from '@/lib/crm-page-contracts.mjs';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  return Astro.redirect(`/crm/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const supabase = (Astro.locals as any).supabase;
let loadError: string | null = null;
let invoices: any[] = [];

const statusFilter = String(Astro.url.searchParams.get('status') ?? '').trim().toLowerCase();
const query = String(Astro.url.searchParams.get('q') ?? '').trim().toLowerCase();
const fromDate = String(Astro.url.searchParams.get('from') ?? '').trim();
const toDate = String(Astro.url.searchParams.get('to') ?? '').trim();

if (!supabase) {
  loadError = 'Supabase is not configured for this environment yet.';
} else {
  const { data, error } = await supabase
    .from('invoices')
    .select('id, invoice_number, status, total_amount, created_at, external_provider, external_invoice_id, client:clients(display_name)')
    .order('created_at', { ascending: false });

  if (error) {
    console.error('Failed to load invoices', error);
    loadError = error.message;
  } else {
    invoices = data ?? [];
  }
}

const filteredInvoices = invoices.filter((invoice) => {
  const matchesStatus = !statusFilter || invoice.status === statusFilter;
  const haystack = [invoice.invoice_number, invoice.client?.display_name, invoice.status, invoice.external_provider, invoice.external_invoice_id]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
  const matchesQuery = !query || haystack.includes(query);
  const invoiceDate = String(invoice.created_at ?? '').slice(0, 10);
  const matchesFrom = !fromDate || (invoiceDate && invoiceDate >= fromDate);
  const matchesTo = !toDate || (invoiceDate && invoiceDate <= toDate);
  return matchesStatus && matchesQuery && matchesFrom && matchesTo;
});

const statusCounts = {
  all: invoices.length,
  draft: invoices.filter((invoice) => invoice.status === 'draft').length,
  issued: invoices.filter((invoice) => invoice.status === 'issued').length,
  paid: invoices.filter((invoice) => invoice.status === 'paid').length,
  void: invoices.filter((invoice) => invoice.status === 'void').length,
};
---

<CrmLayout title="Invoices" description="Bloomwood CRM invoices">
  <section class="mb-6 flex items-center justify-between gap-3">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Invoices</p>
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">All invoices</h2>
    </div>
  </section>

  {loadError ? <section class="rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-950">{loadError}</section> : null}

  <section class="mb-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <form method="get" class="grid gap-4 md:grid-cols-[minmax(0,1fr)_220px_180px_180px_auto] md:items-end">
      <label class="text-sm text-slate-700">
        <span class="mb-1 block">Search</span>
        <input name="q" value={Astro.url.searchParams.get('q') ?? ''} class="w-full rounded-lg border border-slate-300 px-3 py-2" placeholder="Invoice number, client, status" />
      </label>
      <label class="text-sm text-slate-700">
        <span class="mb-1 block">Status</span>
        <select name="status" class="w-full rounded-lg border border-slate-300 px-3 py-2">
          <option value="" selected={!statusFilter}>All statuses</option>
          <option value="draft" selected={statusFilter === 'draft'}>Draft</option>
          <option value="issued" selected={statusFilter === 'issued'}>Issued</option>
          <option value="paid" selected={statusFilter === 'paid'}>Paid</option>
          <option value="void" selected={statusFilter === 'void'}>Void</option>
        </select>
      </label>
      <label class="text-sm text-slate-700">
        <span class="mb-1 block">From</span>
        <input type="date" name="from" value={fromDate} class="w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <label class="text-sm text-slate-700">
        <span class="mb-1 block">To</span>
        <input type="date" name="to" value={toDate} class="w-full rounded-lg border border-slate-300 px-3 py-2" />
      </label>
      <div class="flex gap-2">
        <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700">Filter</button>
        <a href="/crm/invoices/" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Clear</a>
      </div>
    </form>

    <div class="mt-4 flex flex-wrap gap-2 text-sm">
      <a href={`/crm/invoices/?${new URLSearchParams({ ...(query ? { q: query } : {}), ...(fromDate ? { from: fromDate } : {}), ...(toDate ? { to: toDate } : {}) }).toString()}`} class={`rounded-full px-3 py-1 ${!statusFilter ? 'bg-sky-100 text-sky-800' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>All ({statusCounts.all})</a>
      <a href={`/crm/invoices/?${new URLSearchParams({ status: 'draft', ...(query ? { q: query } : {}), ...(fromDate ? { from: fromDate } : {}), ...(toDate ? { to: toDate } : {}) }).toString()}`} class={`rounded-full px-3 py-1 ${statusFilter === 'draft' ? 'bg-sky-100 text-sky-800' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>Draft ({statusCounts.draft})</a>
      <a href={`/crm/invoices/?${new URLSearchParams({ status: 'issued', ...(query ? { q: query } : {}), ...(fromDate ? { from: fromDate } : {}), ...(toDate ? { to: toDate } : {}) }).toString()}`} class={`rounded-full px-3 py-1 ${statusFilter === 'issued' ? 'bg-sky-100 text-sky-800' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>Issued ({statusCounts.issued})</a>
      <a href={`/crm/invoices/?${new URLSearchParams({ status: 'paid', ...(query ? { q: query } : {}), ...(fromDate ? { from: fromDate } : {}), ...(toDate ? { to: toDate } : {}) }).toString()}`} class={`rounded-full px-3 py-1 ${statusFilter === 'paid' ? 'bg-sky-100 text-sky-800' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>Paid ({statusCounts.paid})</a>
      <a href={`/crm/invoices/?${new URLSearchParams({ status: 'void', ...(query ? { q: query } : {}), ...(fromDate ? { from: fromDate } : {}), ...(toDate ? { to: toDate } : {}) }).toString()}`} class={`rounded-full px-3 py-1 ${statusFilter === 'void' ? 'bg-sky-100 text-sky-800' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>Void ({statusCounts.void})</a>
    </div>
  </section>

  <section class="space-y-3 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    {filteredInvoices.length === 0 ? <p class="text-sm text-slate-600">No invoices match the current filters.</p> : null}
    {filteredInvoices.map((invoice) => (
      <a href={`/crm/invoices/${invoice.id}`} class="block rounded-xl border border-slate-200 p-4 hover:border-sky-300">
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="text-base font-semibold text-slate-900">{invoice.invoice_number ?? 'Draft invoice'}</div>
            <div class="text-sm text-slate-600">{invoice.client?.display_name ?? 'Unknown client'}</div>
            <div class="text-sm text-slate-600">Status: {invoice.status}</div>
            {invoice.external_provider ? <div class="text-sm text-slate-600">Provider: {invoice.external_provider}</div> : null}
            {invoice.external_invoice_id ? <div class="text-sm text-slate-600">External ID: {invoice.external_invoice_id}</div> : null}
          </div>
          <div class="text-right text-sm text-slate-600">
            <div class="font-semibold text-slate-900">${Number(invoice.total_amount ?? 0).toFixed(2)}</div>
            <div>{formatCrmDateTime(invoice.created_at)}</div>
          </div>
        </div>
      </a>
    ))}
  </section>
</CrmLayout>
