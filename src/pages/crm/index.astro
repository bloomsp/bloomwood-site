---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  const next = encodeURIComponent(Astro.url.pathname || '/crm');
  return Astro.redirect(`/crm/login?next=${next}`);
}

const supabase = (Astro.locals as any).supabase;

let activeJobsCount = 0;
let overdueTasksCount = 0;
let todayFollowUpsCount = 0;

if (supabase) {
  const nowIso = new Date().toISOString();
  const startOfTomorrow = new Date();
  startOfTomorrow.setHours(24, 0, 0, 0);

  const [jobsResult, overdueTasksResult, todayTasksResult] = await Promise.all([
    supabase.from('jobs').select('id', { count: 'exact', head: true }).not('status', 'in', '(completed,cancelled)'),
    supabase.from('tasks').select('id', { count: 'exact', head: true }).not('status', 'in', '(done,cancelled)').lt('due_at', nowIso),
    supabase.from('tasks').select('id', { count: 'exact', head: true }).not('status', 'in', '(done,cancelled)').gte('due_at', nowIso).lt('due_at', startOfTomorrow.toISOString()),
  ]);

  activeJobsCount = jobsResult.count ?? 0;
  overdueTasksCount = overdueTasksResult.count ?? 0;
  todayFollowUpsCount = todayTasksResult.count ?? 0;
}
---

<CrmLayout title="CRM Dashboard" description="Bloomwood CRM dashboard">
  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm text-slate-500">Today</div>
      <div class="mt-2 text-3xl font-semibold">{todayFollowUpsCount}</div>
      <div class="mt-1 text-sm text-slate-600">follow-ups due</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm text-slate-500">Active jobs</div>
      <div class="mt-2 text-3xl font-semibold">{activeJobsCount}</div>
      <div class="mt-1 text-sm text-slate-600">in progress right now</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm text-slate-500">Overdue tasks</div>
      <div class="mt-2 text-3xl font-semibold">{overdueTasksCount}</div>
      <div class="mt-1 text-sm text-slate-600">needs attention</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm text-slate-500">Signed in</div>
      <div class="mt-2 text-base font-semibold break-all">{user.email}</div>
      <div class="mt-1 text-sm text-slate-600">magic link session active</div>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">CRM dashboard</h2>
    <p class="mt-3 text-sm leading-6 text-slate-600">
      This dashboard now reflects live job and task counts so it stays aligned with the rest of the CRM.
    </p>
  </section>
</CrmLayout>
