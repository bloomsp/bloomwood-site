---
import CrmLayout from '@/layouts/CrmLayout.astro';

export const prerender = false;

const user = (Astro.locals as any).supabaseUser;
if (!user) {
  const next = encodeURIComponent(Astro.url.pathname || '/crm');
  return Astro.redirect(`/crm/login?next=${next}`);
}
---

<CrmLayout title="CRM Dashboard" description="Bloomwood CRM dashboard">
  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm text-slate-500">Today</div>
      <div class="mt-2 text-3xl font-semibold">0</div>
      <div class="mt-1 text-sm text-slate-600">follow-ups due</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm text-slate-500">Active jobs</div>
      <div class="mt-2 text-3xl font-semibold">0</div>
      <div class="mt-1 text-sm text-slate-600">in progress right now</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm text-slate-500">Overdue tasks</div>
      <div class="mt-2 text-3xl font-semibold">0</div>
      <div class="mt-1 text-sm text-slate-600">needs attention</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-sm text-slate-500">Signed in</div>
      <div class="mt-2 text-base font-semibold break-all">{user.email}</div>
      <div class="mt-1 text-sm text-slate-600">magic link session active</div>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">CRM shell is live</h2>
    <p class="mt-3 text-sm leading-6 text-slate-600">
      This is the protected starting point for the internal CRM. Next we can wire real client, job, note,
      and task views onto this shell.
    </p>
  </section>
</CrmLayout>
