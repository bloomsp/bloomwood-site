{
  "name": "bloomwood-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test:crm": "node --test tests/crm-metrics.test.mjs tests/crm-page-contracts.test.mjs",
    "test:ui": "node --test tests/crm-ui-contracts.test.mjs",
    "cf:check": "npm run build && wrangler deploy --dry-run --config dist/server/wrangler.json",
    "cf:dev": "npm run build && wrangler dev --config dist/server/wrangler.json",
    "deploy": "npm run build && wrangler deploy --config dist/server/wrangler.json",
    "downloads:upload": "node scripts/upload-download-files.mjs",
    "downloads:issue": "node scripts/issue-download-link.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-aspect-ratio": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-menubar": "^1.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.1",
    "vite": "^7.3.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@tailwindcss/typography": "^0.5.20",
    "playwright": "^1.58.2",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "sitemap@<=9.0.0": "9.0.0"
